bool encryption=true;
int maxvoicebytes=262144; // ~256 KB; the server drops voice packets larger than this (anti-flood).
int writetime=10000;
dictionary verified_logins;
timer writetimer;
bool restart_pending=false; // a /restart countdown is in progress
int restart_delay=0;        // how long (ms) the countdown runs before relaunch
timer restart_timer;
network net;
network_event event;

/* The standard "target not found" reply for a player-targeting command that requires an ONLINE target: a
registered-but-offline account gets "not online", an unknown name gets "does not exist". (/unban is the one
exception -- it's offline-capable, so it sends only the "does not exist" half directly.) */
void reply_target_not_found(int peer_id, string name)
{
if(account_exists(name)) send(peer_id, "misc This player is not online.", 0, true);
else send(peer_id, "misc This player does not exist.", 0, true);
}
/* Shared validation for /mute and /unmute (their only difference is the action body). Resolves the online
target, validates the channel, and applies the at-or-below-rank gate, replying with the right error (verb =
"mute"/"unmute") on any failure. Returns the target's roster index on success, or -1 if it already sent an
error and the caller should stop. */
int resolve_mute_target(int actor, string tname, string channel, string verb)
{
int ti = get_player_index_from(tname); // online-only, by username or nickname
if(ti < 0) { reply_target_not_found(event.peer_id, tname); return -1; }
if(channel != "all" && !valid_mute_channel(channel)) { send(event.peer_id, "Unknown channel. Use global, local, voice, team, or all.", 0, true); return -1; }
if(rank_level(players[ti].rank) > rank_level(players[actor].rank)) { send(event.peer_id, "You can't "+verb+" someone above your own rank.", 0, true); return -1; }
return ti;
}
string format_uptime(int uptime_seconds)
{
    int days = uptime_seconds / 86400;
    int hours = (uptime_seconds % 86400) / 3600;
    int minutes = (uptime_seconds % 3600) / 60;
    int seconds = uptime_seconds % 60;
    string uptime_message = "Server Uptime: ";
    if (days > 0)
    {
        uptime_message += string(days) + (days == 1 ? " day, " : " days, ");
    }
    if (hours > 0 || days > 0)
    {
        uptime_message += string(hours) + (hours == 1 ? " hour, " : " hours, ");
    }
    if (minutes > 0 || hours > 0 || days > 0)
    {
        uptime_message += string(minutes) + (minutes == 1 ? " minute, " : " minutes, ");
    }
    uptime_message += string(seconds) + (seconds == 1 ? " second." : " seconds.");
    return uptime_message;
}
/* --- All-time peak concurrent players (reported alongside uptime on F4), persisted in data/preffs/peak.svr ---
Zero-pad a non-negative int to at least 2 digits ("5" -> "05") for the peak timestamp. */
string pad2(int n) { string s = "" + n; return (s.length() < 2) ? "0" + s : s; }
// The current local date and time like "12/22/2022 at 5:45 PM" (US M/D/Y, 12-hour clock, no seconds).
string format_now_stamp()
{
int h = TIME_HOUR;                        // 0-23
string ampm = (h < 12) ? "AM" : "PM";
int h12 = h % 12; if(h12 == 0) h12 = 12;  // 0 and 12 both read as 12
return pad2(DATE_MONTH) + "/" + pad2(DATE_DAY) + "/" + DATE_YEAR + " at " + h12 + ":" + pad2(TIME_MINUTE) + " " + ampm;
}
// Players currently LIVE (connected, not on a 45s reconnect hold) -- the server-wide count the peak tracks.
int live_player_count()
{
int n = 0;
for(uint i=0; i<players.length(); i++) if(!players[i].held) n++;
return n;
}
// Load the all-time peak from data/preffs/peak.svr (line 1 = count, line 2 = the formatted date/time). Missing file = no peak yet.
void load_peak()
{
peak_players = 0; peak_when = "";
if(!file_exists("data/preffs/peak.svr")) return;
file pf;
if(!pf.open("data/preffs/peak.svr", "rb")) return;
string raw = pf.read(); pf.close();
string[] lines = string_split(raw, "\r\n", true);
if(lines.length() >= 1) peak_players = int(string_to_number(lines[0].trim_whitespace()));
if(lines.length() >= 2) peak_when = lines[1];
}
// Persist the current peak to data/preffs/peak.svr.
void save_peak()
{
file pf;
if(!pf.open("data/preffs/peak.svr", "wb")) return;
pf.write("" + peak_players + "\r\n" + peak_when + "\r\n");
pf.close();
}
// After a player joins (fresh spawn or reconnect), bump the all-time peak if the live count is a new record.
void update_peak()
{
int n = live_player_count();
if(n > peak_players) { peak_players = n; peak_when = format_now_stamp(); save_peak(); }
}
/* --- Player reports (filed with /report, reviewed by staff with /reports), persisted in data/preffs/reports.svr ---
A readable local timestamp for a report, e.g. "July 8, 2026 at 3:42 PM" (month name, 12-hour, no seconds),
matching the "Member since" style on the account card. */
string report_time_stamp()
{
int h = TIME_HOUR;
string ampm = (h < 12) ? "AM" : "PM";
int h12 = h % 12; if(h12 == 0) h12 = 12;
return DATE_MONTH_NAME + " " + DATE_DAY + ", " + DATE_YEAR + " at " + h12 + ":" + pad2(TIME_MINUTE) + " " + ampm;
}
/* Append one report to data/preffs/reports.svr. One report per line, TAB-delimited:
<stamp>\t<reporter>\t<reported>\t<location>\t<reason>. Tabs, not the colon used elsewhere, because the readable
stamp contains colons; the reason is last so it may contain anything (including tabs, rejoined on read). Nothing
is ever deleted -- a host hand-clears the file if it grows too long. Rewrites the whole file (reports are rare). */
void add_report(string reporter, string reported, string location, string reason)
{
string existing = "";
if(file_exists("data/preffs/reports.svr"))
{
file rf; if(rf.open("data/preffs/reports.svr", "rb")) { existing = rf.read(); rf.close(); }
}
string line = report_time_stamp() + "\t" + reporter + "\t" + reported + "\t" + location + "\t" + reason;
file wf;
if(!wf.open("data/preffs/reports.svr", "wb")) return;
wf.write(existing + line + "\n");
wf.close();
}
// The staff /reports viewer: every report on record, newest first, numbered, in three-line blocks.
string format_reports()
{
if(!file_exists("data/preffs/reports.svr")) return "There are no reports on record.";
file rf;
if(!rf.open("data/preffs/reports.svr", "rb")) return "There are no reports on record.";
string raw = rf.read(); rf.close();
string[] lines = string_split(raw, "\n", true);
string listing = "";
int shown = 0;
for(int i = int(lines.length()) - 1; i >= 0; i--) // newest first: the file is appended in chronological order
{
if(lines[i].trim_whitespace() == "") continue;
string[] parts = string_split(lines[i], "\t", true);
if(parts.length() < 5) continue;
string reason = string_join(parts, "\t", 4); // rejoin the reason (may itself contain tabs)
shown++;
if(shown > 1) listing += "\r\n\r\n";
listing += shown + ". " + parts[1] + ", reported on " + parts[0] + ".\r\n";
listing += "Reported " + parts[2] + ", in " + parts[3] + ".\r\n";
listing += "Reason: " + reason;
}
if(listing == "") return "There are no reports on record.";
return listing;
}
/* Read-only overview for the developer /bansall command: every account that currently holds an active ban. Bans
live on offline account folders, so there's no in-memory list -- we scan them all. Expired timed bans are
skipped. Listed in the order find_directories returns (there's no ban timestamp to sort by). */
string format_all_bans()
{
string[] dirs = find_directories("data/players/*");
string listing = "";
int shown = 0;
for(uint i=0; i<dirs.length(); i++)
{
int64 until = get_ban_until(dirs[i]); // -1 not banned, 0 permanent, >0 epoch it expires at
if(until < 0) continue;
if(until > 0 and until - now_epoch() <= 0) continue; // timed ban already lapsed
string reason = get_ban_reason(dirs[i]);
string suffix = (reason == "") ? "" : " Reason: " + reason;
string status = (until == 0) ? "banned permanently" : ("banned, with " + format_duration(until - now_epoch()) + " remaining");
shown++;
if(shown > 1) listing += "\r\n\r\n";
listing += shown + ". " + dirs[i] + " is " + status + "." + suffix;
}
if(listing == "") return "There are no banned accounts on record.";
return listing;
}
string string_join(string[]@ arr, string delimiter, uint start_index = 0, uint end_index = 0)
{
    if (end_index == 0 || end_index > arr.length())
{
        end_index = arr.length();
    }
    string result = "";
    for (uint i = start_index; i < end_index; i++)
{
        result += arr[i];
        if (i < end_index - 1)
{
            result += delimiter;
        }
    }
    return result;
}
int get_player_index(int id)
{
for(int i=0; i<players.length(); i++)
{
if(players[i].peer_id==id)
return i;
}
return -1;
}
/* Resolve a typed name to an ONLINE player: username first (the stable identity), then nickname (the
display name). Case-INSENSITIVE, matching login/account lookups and get_online_index -- an account is a
case-insensitive identity (you can't have both "bob" and "Bob"), so "/mute Bob" correctly targets account
"bob". Nicknames are unique case-insensitively among online players (and vs usernames), so a nickname match
stays unambiguous, and a real username always wins over a coincidental nickname. */
int get_player_index_from(string name)
{
string low=string_to_lower_case(name);
for(int i=0; i<players.length(); i++)
if(string_to_lower_case(players[i].name)==low) return i;
for(int i=0; i<players.length(); i++)
if(string_to_lower_case(players[i].nickname)==low) return i;
return -1;
}
/* Maps a peer id -> the username it successfully authenticated as in login(). spawn_player seats a peer ONLY
as its verified name, so a peer can't log in as one account and spawn as another, and can't spawn without
logging in at all. The entry is removed when the peer disconnects. */
void login(string name, string password, string ver)
{
if(ver != version)
{
/* Direction-aware: a client older than the server should update its game; a client NEWER than the server means
the SERVER is the one behind, so don't wrongly tell the player to update. version strings are "major.minor"
with minors that always roll over at .9, so a plain numeric compare orders them correctly. */
if(string_to_number(ver) < string_to_number(version))
send(event.peer_id, "error: your game is out of date. your version: "+ver+", server version: "+version+". Please update your game to connect to this server.", 0,true);
else
send(event.peer_id, "error: this server is out of date. your version: "+ver+", server version: "+version+". The server needs to be updated before you can connect.", 0,true);
return;
}
if(!account_exists(name))
{
send(event.peer_id, "error: no account with that name exists. Please create one first.", 0,true);
return;
}
if(!verify_password(name, password))
{
send(event.peer_id, "error: incorrect password.", 0,true);
return;
}
/* Email is mandatory as of the email update: an older account created before it has no email.usr, so it's
refused here and the player must make a new account (which collects an email) to play. */
if(read_field(name, "email") == "")
{
send(event.peer_id, "error: this account predates the required email and can no longer be used; please create a new account.", 0,true);
return;
}
int64 bu = get_ban_until(name);
string breason = get_ban_reason(name);
string bsuffix = (breason == "") ? "" : " Reason: " + breason;
if(bu == 0)
{
send(event.peer_id, "error: you are banned from this server."+bsuffix, 0,true);
return;
}
else if(bu > 0)
{
int64 nowsec = now_epoch();
if(nowsec >= bu)
{
clear_ban(name);
}
else
{
send(event.peer_id, "error: you are banned for "+int(bu - nowsec)+" seconds."+bsuffix, 0,true);
return;
}
}
bool cont=true;
for(uint i=0; i<players.length(); i++)
{
if(players[i].name==name)
{
/* This account already has a session in the roster: either a HELD one (dropped, holding its slot within the
grace window) or a still-LIVE one -- a ghost the server's enet hasn't timed out yet, or a genuine second
login. In every case this IS the same account (re)connecting, so ADOPT that session onto this new peer and
restore their scope, rather than tearing it down and dumping them in the lobby. This makes reconnect work
whether or not the grace hold has engaged yet (killing the detect-the-drop race), and a real second login
simply takes the session over into wherever it was. Rebind repoints members[]/host_peer + the roster entry;
spawn_player then replays their game/room/watch scope with inventory and host status intact. */
int oldpeer=players[i].peer_id;
bool washeld=players[i].held;
if(!washeld) net.disconnect_peer_forcefully(oldpeer); // a live old socket (real second client, or a not-yet-timed-out ghost): drop it so two clients don't both drive one session
rebind_peer(oldpeer, event.peer_id);
players[i].held=false;
players[i].restoring=true;
players[i].restore_reannounce=washeld; // held sessions were announced offline, so restore re-announces them online; a live takeover never went offline, so it stays quiet
verified_logins.delete(""+oldpeer);
verified_logins.set(""+event.peer_id, name);
send(event.peer_id, "done", 0,true);
return;
}
}
if(players.length()>=userlimit)
{
cont=false;
send(event.peer_id, "error: the server has exceeded the limit. the maximum number of players is "+userlimit, 0,true);
}
if(cont==true)
{
verified_logins.set(""+event.peer_id, name); // remember who this peer authenticated as; spawn_player trusts only this
send(event.peer_id, "done", 0,true);
}
}
void register_account(string name, string email, string password)
{
if(name.length()<6 or name.length()>24)
{
send(event.peer_id, "error: usernames must be between 6 and 24 characters.", 0,true);
return;
}
if(filterchar(name, true))
{
send(event.peer_id, "error: usernames may only contain letters, numbers, hyphens and underscores.", 0,true);
return;
}
if(account_exists(name))
{
send(event.peer_id, "error: an account with that name already exists.", 0,true);
return;
}
/* The email is cosmetic and unverified; just require a plausible non-empty value (the client asks for a real
one). It's stored as-is in email.usr and never used for login. */
if(email == "" or string_contains(email, "@", 1) < 0)
{
send(event.peer_id, "error: a valid email address is required.", 0,true);
return;
}
if(password.length()<6 or password.length()>24)
{
send(event.peer_id, "error: passwords must be between 6 and 24 characters.", 0,true);
return;
}
if(create_account(name, email, password))
{
send(event.peer_id, "registered", 0,true);
/* Tell everyone already online that a new account was made, right now at creation time (before the new
player has logged in). The registrant isn't in the roster yet, so this loop naturally skips them. */
for(uint i=0; i<players.length(); i++) send(players[i].peer_id, "newchar "+name, 0, true);
}
else
{
send(event.peer_id, "error: failed to create the account.", 0,true);
}
}
/* Builds the /restart countdown sentence. 60 seconds or more is expressed in whole minutes
(floored), anything less is expressed in seconds. */
string format_restart_time(int seconds)
{
if(seconds>=60)
{
int mins=seconds/60;
if(mins==1) return "Attention! The server will restart in 1 minute.";
return "Attention! The server will restart in "+mins+" minutes.";
}
return "Attention! The server will restart in "+seconds+" seconds.";
}
/* Closes the server. Forcefully disconnects every client first so each one's enet sees the drop
immediately and bounces back to its connection menu, pumps the host briefly so those
disconnects actually flush out, then exits the process. Used by both /restart (after its
countdown) and /fastrestart (immediately). Bringing the server back up is handled externally. */
void do_restart()
{
for(uint i=0; i<players.length(); i++)
{
net.disconnect_peer_forcefully(players[i].peer_id);
}
timer flush;
flush.restart();
while(flush.elapsed<300)
{
net.request();
wait(5);
}
exit();
}
/* Carries out a ban that has already passed the rank and target checks, shared by /ban (permanent) and
/tempban (timed). dur is the length in whole seconds (0 = permanent); reason is "" when none was given.
Records the ban with its reason, drops the target from the roster, tells them (with the reason), announces
the ban to everyone (without the reason -- that's staff-only), and confirms it to the acting staff member. */
void perform_ban(int actorpeer, int ti, int dur, string reason)
{
/* The reason is shown to the banned player (login rejection) and to staff in /bans, so a screen reader crash
string in it must never get through. Staff reasons are crash-filtered ONLY, not profanity-filtered, so staff
can quote what a player did; a reason that trips the crash filter is dropped and the ban still applies. */
bool reason_dropped = (reason != "" and filter_crash(reason));
if(reason_dropped) reason = "";
int64 until = (dur > 0) ? (now_epoch() + dur) : 0;
int tpeer = players[ti].peer_id;
string realname = players[ti].name;
string trank = players[ti].rank;
string tnick = players[ti].nickname;
string tdisp = display_name_flagged(ti);
set_ban(realname, until, reason);
players.remove_at(ti);
send(tpeer, "banned " + dur + (reason == "" ? "" : " " + reason), 0, true);
for(uint i=0; i<players.length(); i++)
{
send(players[i].peer_id, "banannounce " + realname + " " + trank + " " + tnick, 0, true);
}
string rp = (reason == "") ? "." : ", with the reason: " + reason;
if(dur > 0) send(actorpeer, "misc " + tdisp + " has been banned for " + dur + " seconds" + rp, 0, true);
else send(actorpeer, "misc " + tdisp + " has been banned permanently" + rp, 0, true);
if(reason_dropped) send(actorpeer, "misc That reason contained a screen reader crash string, so the ban went through without it.", 0, true);
}
// Case-insensitive roster lookup by name; returns -1 if the player isn't connected.
int get_online_index(string name)
{
string low=string_to_lower_case(name);
for(uint i=0; i<players.length(); i++)
{
if(players[i].held) continue; // a held (disconnected, holding their slot) session reads as offline: not targetable, not counted "online"
if(string_to_lower_case(players[i].name)==low) return i;
}
return -1;
}
// Case-insensitive check of whether a named account is currently connected.
bool is_online(string name)
{
return get_online_index(name)>-1;
}
/* --- Reconnect grace (hold-and-restore) ---
How long a dropped session's game/room slot, host status, and inventory are held before the real teardown
runs, if they never reconnect. Matches the client's auto-retry window so the automatic reconnect covers the
entire hold. */
const int reconnect_grace_ms=45000;
/* Repoint every stored reference from oldpeer to newpeer across games and rooms (both member lists and
host_peer) and the roster entry itself. Used to swap a session onto a negative sentinel id when it goes on
hold, and back onto the real new peer id when it reconnects, so a held slot survives the peer-id change with
no dangling references anywhere. */
void rebind_peer(int oldpeer, int newpeer)
{
for(uint i=0; i<games.length(); i++)
{
if(games[i].host_peer==oldpeer) games[i].host_peer=newpeer;
for(uint j=0; j<games[i].members.length(); j++)
if(games[i].members[j]==oldpeer) games[i].members[j]=newpeer;
}
for(uint i=0; i<rooms.length(); i++)
{
if(rooms[i].host_peer==oldpeer) rooms[i].host_peer=newpeer;
for(uint j=0; j<rooms[i].members.length(); j++)
if(rooms[i].members[j]==oldpeer) rooms[i].members[j]=newpeer;
}
int pi=get_player_index(oldpeer);
if(pi>-1) players[pi].peer_id=newpeer;
}
/* Is this session worth holding on a drop? True if they're in a non-lobby space (a room, office, game, or
watching -- room_id != 0) or they host a live room or game. A bare lobby session with nothing hosted has
nothing to restore, so it's torn down immediately instead of held. */
bool has_restorable_state(int index)
{
if(index<0 or index>=int(players.length())) return false;
if(players[index].room_id != 0) return true;
int peer=players[index].peer_id;
for(uint i=0; i<rooms.length(); i++) if(rooms[i].host_peer==peer) return true;
for(uint i=0; i<games.length(); i++) if(games[i].host_peer==peer) return true;
return false;
}
/* Put a dropped session on hold for the grace window instead of tearing it down: announce them offline (the
same connections-buffer notice as a normal disconnect) and strip their presence from the space they're in,
but KEEP their roster entry, game/room membership, host status, and inventory. Their dead peer id is swapped
for a unique negative sentinel so a recycled enet peer can't collide with the held slot. The netloop poll
runs the real teardown once held_timer passes reconnect_grace_ms; a reconnect (login) restores them first. */
void begin_hold(int index)
{
players[index].held=true;
players[index].held_timer.restart();
players[index].afk=false; // they're simply gone now, not away-at-keyboard
send(0, "offline "+players[index].name+" "+players[index].rank+" "+players[index].nickname, 0,true);
if(players[index].spectating)
{
// To the game they were watching, they simply stopped watching (they aren't in anyone's tracker anyway).
string wn=display_name_flagged(index)+" stopped watching.";
for(uint i=0; i<players.length(); i++)
if(players[i].room_id==players[index].room_id and i!=uint(index)) send(players[i].peer_id, "misc "+wn, 0, true);
}
else
{
// Despawn them from their space-mates so their beacon/footsteps stop; broadcasts about them are otherwise suppressed while held.
for(uint i=0; i<players.length(); i++)
if(i!=uint(index) and players[i].room_id==players[index].room_id and !players[i].held) send(players[i].peer_id, "despawn "+players[index].name, 0, true);
}
int oldpeer=players[index].peer_id;
int sentinel=next_held_id; next_held_id--;
verified_logins.delete(""+oldpeer); // the reconnect sets a fresh verified_logins entry for the new peer
rebind_peer(oldpeer, sentinel);
}
/* Send a peer the CURRENT phase of a game for a mid-round arrival (join, spectate, or reconnect restore): the
accurate remaining time -- the build countdown, or an EVP wave's remaining round-timer seconds that the
client counts down locally -- plus, if we're mid-wave in a REST window, the segment sync so the client shows
the right window and pauses its EVP countdown. Without this a mid-round arrival reads "0 seconds left" and
defaults to an attack window until the next natural segment flip. */
void send_game_phase_to(int peer, int gi)
{
if(gi<0 or gi>=int(games.length())) return;
int rem;
if(games[gi].phase=="build") rem = games[gi].buildduration - int(games[gi].phasetimer.elapsed/1000);
else if(games[gi].mode=="evp" and games[gi].phase=="wave") rem = games[gi].evp_round_secs - int(games[gi].wavetimer.elapsed/1000);
else rem = 0;
if(rem<0) rem=0;
send(peer, "gamephase "+games[gi].phase+" "+rem+" "+games[gi].wave_number, 0, true);
/* The gamephase handler assumes a wave opens ATTACKING; if we're actually in a rest window, sync that (this
also pauses the client's EVP round-timer countdown so rem holds). An attack window needs nothing more. */
if(games[gi].phase=="wave" and !games[gi].wave_attacking) send(peer, "waveseg 0 "+games[gi].wave_number, 0, true);
}
/* Re-open (silently, no death boom) any already-breached walls on a client that just drew a FRESH intact cavern
-- used by a mid-round join and a reconnect restore, so a player doesn't bump a gap that is actually open (the
client enforces wall collision by tile, and draw_map re-lays all four walls solid). Spectators don't need this:
they roam the deck behind their own indestructible border, and the client's re-tile is guarded by !watching. */
void send_wall_breaches(int peer, int gi)
{
if(gi<0 or gi>=int(games.length())) return;
string[]@ bdirs = WALL_DIRS;
for(uint bd=0; bd<bdirs.length(); bd++)
{
int bwi = wall_in_dir(games[gi].id, bdirs[bd], games[gi].size); // mode-aware: PVP's inset ring, the outer border otherwise
if(bwi>-1 and walls[bwi].health<=0) send(peer, "wallbreach "+bdirs[bd], 0, true);
}
}
/* Replay a reconnected (restored) player's current space to their fresh client, changing none of their held
state (membership, host status, inventory). Mirrors what join_game_now / do_spectate / do_join_room send on
entry, but mutates nothing except re-centring their position -- the client re-centres `me` on the redraw, so
the server must match (as after a round reset) or reach checks would misfire. broadcast_pos re-adds them to
everyone else's tracker. Their room_id already reflects wherever the hold left them (their game, a room, the
lobby, or a watch), including any space change forced while they were held (e.g. their game ended). */
void restore_scope(int index)
{
int peer=players[index].peer_id;
int rid=players[index].room_id;
int gi=get_game_index(rid);
int center=25; // lobby/office are 50x50 (centre 25); a game cavern is size/2
if(gi>-1) center=games[gi].size/2;
players[index].x=center;
players[index].y=center;
if(players[index].spectating and gi>-1)
{
// Back onto the overhead deck of the game they were watching.
send(peer, "spectatejoined "+games[gi].id+" "+games[gi].size+" "+games[gi].mode+" "+(players[index].spectate_outside?"out":"in")+" "+games[gi].host+"\n"+display_name_flagged_for(games[gi].host), 0, true);
for(uint i=0; i<players.length(); i++)
if(i!=uint(index) and players[i].room_id==rid and !players[i].spectating and !players[i].held) send(peer, pos_msg(int(i)), 0, true);
for(uint i=0; i<items.length(); i++)
if(@items[i]!=null and items[i].room_id==rid) send(peer, "spawnitem "+items[i].id+" "+items[i].type+" "+items[i].x+" "+items[i].y, 0, true);
send_builders_to(peer, rid);
send(peer, wall_strength_msg(rid), 0, true);
send_game_phase_to(peer, gi);
if(games[gi].paused) send(peer, "gamepaused", 0, true);
return;
}
if(gi>-1)
{
// Back into the cavern as a member, with their preserved inventory.
send(peer, "gamejoined "+games[gi].id+" "+games[gi].size+" "+(games[gi].solo?"solo":"open")+" "+games[gi].mode+" "+games[gi].host+"\n"+display_name_flagged_for(games[gi].host), 0, true);
/* PVP: re-send their side so the fresh client re-learns it (re-spawns to the right place and re-arms if attacking).
Attackers restore out at the exterior entry -- not the centre the redraw assumes -- so set that on the server
too; sent before the gamephase/equipweapon below so the client's PVP auto-arm sees the correct side. */
if(games[gi].mode=="pvp" and players[index].team!="")
{
if(players[index].team=="attack") { int wmin=games[gi].size/4; players[index].x=wmin/2; players[index].y=games[gi].size/2; }
send(peer, "yourside "+players[index].team, 0, true);
}
/* EVP (and a PVP attacker): restore the weapon they had drawn BEFORE the gamephase message, so its auto-axe
(which only fires when the client is unarmed) doesn't override it. PVE members and PVP defenders carry none. */
if((games[gi].mode=="evp" or (games[gi].mode=="pvp" and players[index].team=="attack")) and (games[gi].phase=="build" or games[gi].phase=="wave") and players[index].weapon!="") send(peer, "equipweapon "+players[index].weapon, 0, true);
send_game_phase_to(peer, gi);
send_builders_to(peer, rid);
send(peer, wall_strength_msg(rid), 0, true);
send_wall_breaches(peer, gi); // re-open (silently) any already-breached walls the fresh redraw re-laid solid
for(uint i=0; i<items.length(); i++)
if(@items[i]!=null and items[i].room_id==rid) send(peer, "spawnitem "+items[i].id+" "+items[i].type+" "+items[i].x+" "+items[i].y, 0, true);
send_wood_count(index); // their PRESERVED inventory, not a cleared one
/* Reconnected during the end-of-round results screen: re-send their play-again prompt (the exact roundover/
evpover message), so they can still answer instead of being stuck in an "over" cavern with no prompt -- which
would also block the others' reset, since an unanswered member holds it up. */
if(games[gi].phase=="over" and !players[index].playagain_answered and players[index].pending_results!="") send(peer, players[index].pending_results, 0, true);
if(games[gi].paused) send(peer, "gamepaused", 0, true);
broadcast_pos(index); // re-add them to the other members' trackers (held is already cleared)
for(uint i=0; i<players.length(); i++)
if(i!=uint(index) and players[i].room_id==rid and !players[i].held) send(peer, pos_msg(int(i)), 0, true);
return;
}
int ri=get_room_index(rid);
if(ri>-1)
{
// Back into the office of the room they were in.
send(peer, "roomjoined "+rooms[ri].id+" "+(rooms[ri].is_private?"private":"public")+" "+rooms[ri].host+"\n"+display_name_flagged_for(rooms[ri].host), 0, true);
broadcast_pos(index);
for(uint i=0; i<players.length(); i++)
if(i!=uint(index) and players[i].room_id==rid and !players[i].held) send(peer, pos_msg(int(i)), 0, true);
return;
}
/* Lobby (room_id 0): they were held for hosting a room. The client already drew the lobby on spawn, so just
re-advertise them and hand them the other lobby occupants. */
broadcast_pos(index);
for(uint i=0; i<players.length(); i++)
if(i!=uint(index) and players[i].room_id==0 and !players[i].held) send(peer, pos_msg(int(i)), 0, true);
}
// The capitalized, expanded label shown for a rank in the /staff listing.
string staff_label(string rank)
{
if(rank=="developer") return "Developer";
if(rank=="administrator") return "Administrator";
if(rank=="moderator") return "Moderator";
return rank;
}
/* Scans every account on disk for staff and builds the /staff sentence, listing top of the
hierarchy first (developers, then administrators, then moderators), each tagged (Online) or
(Offline) based on the current roster. */
string build_staff_list()
{
string[] files=find_directories("data/players/*");
string[] devs, admins, mods;
for(uint i=0; i<files.length(); i++)
{
string acct=files[i];
if(acct=="" or acct=="." or acct=="..") continue;
/* Read just the rank first and skip non-staff before touching the rest of the account -- most accounts aren't
staff, so this avoids a full 5-field load_account on every folder each time /staff runs. */
string rank=read_field(acct, "rank", "player");
if(!is_staff(rank)) continue;
string dispname=read_field(acct, "username");
if(dispname=="") dispname=acct;
int oi=get_online_index(dispname);
string status=(oi>-1)? "Online" : "Offline";
string afkp=(oi>-1 and players[oi].afk)? "AFK " : "";
string nick=get_nickname(dispname);
string namepart=(string_to_lower_case(nick)!=string_to_lower_case(dispname)) ? nick+" ("+dispname+")" : dispname;
string entry=afkp+staff_label(rank)+" "+namepart+" ("+status+")";
if(rank=="developer") devs.insert_last(entry);
else if(rank=="administrator") admins.insert_last(entry);
else mods.insert_last(entry);
}
string[] all;
for(uint i=0; i<devs.length(); i++) all.insert_last(devs[i]);
for(uint i=0; i<admins.length(); i++) all.insert_last(admins[i]);
for(uint i=0; i<mods.length(); i++) all.insert_last(mods[i]);
int total=int(all.length());
if(total==0) return "There are no staff members on this game.";
string list=oxford_join(all);
string head;
if(total==1) head="There is 1 staff member on this game. ";
else head="There are "+total+" staff members on this game. ";
return head+list+".";
}
/* Tells a player which of their saved rooms exist so the client can warn before the create flow.
Sends "yourrooms <0/1 public> <0/1 private>". */
void send_yourrooms(int peer, string name)
{
send(peer, "yourrooms "+(get_saved_public(name)?"1":"0")+" "+(get_saved_private(name)!=""?"1":"0"), 0,true);
}
// Sends a message to every online staff member (used by staff chat).
void relay_to_staff(string msg)
{
for(uint i=0; i<players.length(); i++)
{
if(is_staff(players[i].rank)) send(players[i].peer_id, msg, 0, true);
}
}
/* Sends a message to everyone on the sender's team within their game (used by team chat). team splits a game's
players into sides (PVP); in co-op games everyone shares one team, so it reaches the whole game. Respects the
recipient's personal ignore list, like local chat. */
void relay_to_team(int sender_index, string msg)
{
if(sender_index<0 or sender_index>=int(players.length())) return;
int room = players[sender_index].room_id;
string team = players[sender_index].team;
string sender_name = players[sender_index].name;
for(uint i=0; i<players.length(); i++)
{
if(players[i].room_id != room) continue;      // same game space
if(players[i].team != team) continue;         // same side
if(player_ignores(int(i), sender_name)) continue; // recipient ignores the sender
send(players[i].peer_id, msg, 0, true);
}
}
/* Sends a third-person staff audit line (a promote/demote/unban/notify) to every online staff member -- a
moderation record visible only to staff, not regular players, routed to the misc buffer like /warn's staff
notice. skip_peer excludes one peer (e.g. the actor); pass -1 to include everyone, so the actor gets the
third-person copy alongside their own first-person confirmation. */
void notify_staff_audit(string text, int skip_peer)
{
for(uint i=0; i<players.length(); i++)
if(is_staff(players[i].rank) and int(players[i].peer_id) != skip_peer) send(players[i].peer_id, "misc "+text, 0, true);
}
/* Deliver every offline PM queued for a freshly-spawned player, then clear the queue. Each goes as its own control
message so the client shows it in the private chats buffer with the PM sound and sets the reply target to the
sender's USERNAME (so /reply reaches them even if they're still offline). Fresh logins only, never reconnects. */
void deliver_offline_pms(int index)
{
string raw = get_offline_pms(players[index].name);
if(raw == "") return;
string[] lines = string_split(raw, "\n", true);
for(uint i=0; i<lines.length(); i++)
{
if(lines[i].trim_whitespace() == "") continue;
string[] parts = string_split(lines[i], "\t", true);
if(parts.length() < 2) continue;
string sender = parts[0];
string msg = string_join(parts, "\t", 1, parts.length()); // rejoin the message (may contain tabs), everything after the sender
string sdisp = read_field(sender, "nickname", sender); // the sender's current display name, or their username if none/deleted
send(players[index].peer_id, "offlinepm " + sender + "\nOffline PM from " + sdisp + ": " + msg, 0, true);
}
clear_offline_pms(players[index].name);
}
// Sends a message to everyone sharing the given room scope (used by local chat). room_id 0 = lobby.
void relay_to_local(int room_id, string msg, string language="", int sender_index=-1)
{
string sender_name = (sender_index>=0 and sender_index<int(players.length())) ? players[sender_index].name : "";
for(uint i=0; i<players.length(); i++)
{
if(players[i].room_id != room_id) continue;
/* "" (the local-chat callers) = everyone in the space, regardless of language channel; an optional language
filter remains available for any future caller that wants same-language-only delivery in a space. */
if(language != "" and string_to_lower_case(players[i].language) != string_to_lower_case(language)) continue;
if(sender_name != "" and player_ignores(int(i), sender_name)) continue; // recipient has the sender on their personal ignore list
send(players[i].peer_id, msg, 0, true);
}
}
/* Broadcast a global-channel chat message only to players on the same language channel as the sender, so
global chat is scoped per language (like local). PMs and staff chat bypass this and reach across languages. */
void relay_global(int sender_index, string what)
{
if(sender_index < 0 or sender_index >= int(players.length())) return;
string lang = players[sender_index].language;
string sender_name = players[sender_index].name;
for(uint i=0; i<players.length(); i++)
if(string_to_lower_case(players[i].language) == string_to_lower_case(lang) and !player_ignores(int(i), sender_name)) send(players[i].peer_id, what, 1, true); // skip recipients ignoring the sender
}
/* Broadcast a third-person lifecycle notice (room/game created, left, stopped, kicked, etc.) to everyone's
player events buffer, server-wide, skipping the actor(s) who instead get a first-person confirmation in
their own misc buffer. The text should already use a flag-aware name (display_name_flagged[_for]). */
void broadcast_event(string text, int skip1 = -1, int skip2 = -1)
{
for(uint i=0; i<players.length(); i++)
{
if(int(players[i].peer_id) == skip1 or int(players[i].peer_id) == skip2) continue;
send(players[i].peer_id, "event "+text, 0, true);
}
}
/* Change an online player's nickname (ti = their roster index). requested is the new nickname, or "default"
to revert to their account username. Validates format and uniqueness, persists to nickname.usr, updates
the roster + tracker, and alerts everyone. issuer_peer receives any error. byself controls the wording. */
bool apply_nickname(int ti, string requested, int issuer_peer, bool byself)
{
string uname = players[ti].name;
string newnick;
if(string_to_lower_case(requested) == "default") newnick = uname; // revert to the account username
else
{
if(requested.length() < 3 or requested.length() > 24) { send(issuer_peer, "misc Nicknames must be between 3 and 24 characters.", 0, true); return false; }
if(filterchar(requested, true)) { send(issuer_peer, "misc Nicknames may only contain letters, numbers, hyphens and underscores.", 0, true); return false; }
newnick = requested;
}
// No-op if it's already their current nickname: tell them rather than re-announcing the same name.
if(newnick == players[ti].nickname)
{
if(byself) send(issuer_peer, "misc Your nickname is already set to "+newnick+".", 0, true);
else send(issuer_peer, "misc This player's nickname is already set to "+newnick+".", 0, true);
return false;
}
// Must be unique among online players: no one else's nickname OR username may match it (anti-impersonation).
for(uint i=0; i<players.length(); i++)
{
if(int(i) == ti) continue;
if(string_to_lower_case(players[i].nickname) == string_to_lower_case(newnick) or string_to_lower_case(players[i].name) == string_to_lower_case(newnick))
{ send(issuer_peer, "misc This nickname is already taken. Try again.", 0, true); return false; }
}
/* Also reject any EXISTING account's username other than your own (online OR offline), so you can't take a
logged-out player's identity as your display name. Your own username is fine -- that's the default nickname. */
if(string_to_lower_case(newnick) != string_to_lower_case(uname) and account_exists(newnick))
{ send(issuer_peer, "misc This nickname is already taken. Try again.", 0, true); return false; }
string oldannounce = afk_prefix(ti) + display_name_flagged(ti); // old display, AFK + flag aware
players[ti].nickname = newnick;
set_nickname(uname, newnick);
string poss = pronoun_word(players[ti].pronoun, "possessive", oldannounce);
string verb = byself ? (" has changed "+poss+" nickname to ") : "'s nickname has been changed to ";
for(uint i=0; i<players.length(); i++) send(players[i].peer_id, "alert "+oldannounce+verb+newnick+".", 0, true);
broadcast_pos(ti); // refresh the nickname shown in the player tracker
return true;
}
/* Move a player to a new room scope (0 = lobby) and keep everyone's rosters in sync. Position, beacons
and voice are scoped per room: on a move we tell the old scope to drop the player (despawn) and the
new scope to pick them up (exchanging positions both ways). Server-wide online/offline presence is
unaffected. Send the matching roomjoined/roomleft/etc. message to the mover BEFORE calling this, so
their client clears its roster first and then receives the new scope's occupants. */
void set_room_scope(int pindex, int newroom)
{
string nm = players[pindex].name;
int pr = players[pindex].peer_id;
int oldroom = players[pindex].room_id;
for(uint i=0; i<players.length(); i++)
if(i!=uint(pindex) and players[i].room_id==oldroom) send(players[i].peer_id, "despawn "+nm, 0, true);
players[pindex].room_id = newroom;
players[pindex].team = ""; // clear any PVP side when moving between spaces, so it never leaks into another game's team chat; a PVP side is chosen fresh after entering an idle PVP game
/* Spawn at the center of the new space: the lobby and offices are 50x50 (center 25); a game cavern is
sized by its map, so its center is size/2 (matching the client's draw_map centering). */
int center = 25;
int gi = get_game_index(newroom);
if(gi > -1) center = games[gi].size / 2;
players[pindex].x = center;
players[pindex].y = center;
for(uint i=0; i<players.length(); i++)
{
if(i==uint(pindex) or players[i].room_id!=newroom) continue;
if(!players[pindex].held) send(players[i].peer_id, pos_msg(pindex), 0, true); // a held player being shuffled between spaces during a teardown must not be advertised as present
send(pr, pos_msg(int(i)), 0, true);
}
// Send any ground items already in the new space (e.g. wood down in a game you're joining mid-round).
for(uint i=0; i<items.length(); i++)
if(@items[i]!=null and items[i].room_id==newroom) send(pr, "spawnitem "+items[i].id+" "+items[i].type+" "+items[i].x+" "+items[i].y, 0, true);
// Entering a game starts you with no wood (inventory is per-game); sync the cleared count and the walls.
if(gi > -1)
{
players[pindex].inv.clear();
send_wood_count(pindex);
send(pr, wall_strength_msg(newroom), 0, true);
}
}
/* "pos <name> <x> <y> <visible-rank> <afk>" for a player, so the client's player tracker (P) can show the
same flag-aware rank and AFK marker the listings use. visible-rank is the rank only when the player is
staff AND has their flag on, otherwise "player"; afk is 1 or 0. */
string pos_msg(int pindex)
{
string vr = (is_staff(players[pindex].rank) and players[pindex].flagged) ? players[pindex].rank : "player";
string af = players[pindex].afk ? "1" : "0";
return "pos "+players[pindex].name+" "+players[pindex].x+" "+players[pindex].y+" "+vr+" "+af+" "+players[pindex].nickname;
}
/* Broadcast a player's current position to everyone sharing their room scope (used on each move). A
spectator is never advertised -- this single guard keeps watchers out of everyone's player tracker and
beacons (no "pos" means they're never added to other clients' rosters). */
void broadcast_pos(int pindex)
{
if(players[pindex].spectating or players[pindex].held) return; // never advertise a spectator or a held (offline-pending) player's position
for(uint i=0; i<players.length(); i++)
if(players[i].room_id==players[pindex].room_id) send(players[i].peer_id, pos_msg(pindex), 0, true);
}
// Send a player their current wood count so their client's I key can report it.
void send_wood_count(int pindex)
{
send(players[pindex].peer_id, "wood "+players[pindex].inv.count("oak")+" "+players[pindex].inv.count("maple")+" "+players[pindex].inv.count("birch")+" "+players[pindex].inv.count("pine"), 0, true);
}
// Push the player's ammo reserve, by type, to their client (the X-key readout): "ammo <arrow> <gas> <grenade> <powder> <normal>".
void send_ammo_count(int pindex)
{
send(players[pindex].peer_id, "ammo "+players[pindex].inv.count("arrow")+" "+players[pindex].inv.count("gas")+" "+players[pindex].inv.count("grenade")+" "+players[pindex].inv.count("powder")+" "+players[pindex].inv.count("normal"), 0, true);
}
// Zero a player's ammo reserve and its granted-this-round tracking (called at build-phase start so each round starts fresh), then sync the client.
void reset_player_ammo(int pindex)
{
players[pindex].granted_ammo_types.resize(0);
players[pindex].granted_mags.resize(0); // every weapon's free first-draw mag fill re-arms with the new round
players[pindex].mag.clear(); // empty all magazines too
string[] a = ammo_types();
for(uint i=0; i<a.length(); i++) players[pindex].inv.take(a[i], players[pindex].inv.count(a[i])); // drop each ammo type to 0 without touching wood
send_ammo_count(pindex);
}
// The four cavern wall strengths (as percents) for a game, for the client's N/E/S/W/D keys.
string wall_strength_msg(int gameid)
{
int gi = get_game_index(gameid);
if(gi < 0) return "wallstr 0 0 0 0";
double size = games[gi].size;
return "wallstr "+wall_percent(gameid,"north",size)+" "+wall_percent(gameid,"east",size)+" "+wall_percent(gameid,"south",size)+" "+wall_percent(gameid,"west",size);
}
// Push the four wall strengths to everyone in a game (on entry, reinforce, and later damage).
void broadcast_wall_strength(int gameid)
{
string m = wall_strength_msg(gameid);
for(uint i=0; i<players.length(); i++)
if(players[i].room_id == gameid) send(players[i].peer_id, m, 0, true);
}
/* Pick up every wood within `radius` tiles of the player (radius 0 = the exact tile they're on). Only in
a game during the build or wave phase. Adds to the player's inventory, removes the items (telling
everyone in the game), and gives the picker the take sound plus an updated wood count. */
void gather_wood(int pindex, int radius)
{
int rid = players[pindex].room_id;
int gi = get_game_index(rid);
if(gi < 0) return;
if(games[gi].mode == "evp") return; // EVP: the builder bots gather the wood, not the players
if(games[gi].phase != "build" and games[gi].phase != "wave") return;
int px = players[pindex].x;
int py = players[pindex].y;
int got = 0;
string picked_type = "oak"; // the species of a picked piece, so the take sound matches (fallback never used when got>0)
for(int i=int(items.length())-1; i>=0; i--)
{
if(@items[i]==null) continue;
if(items[i].room_id != rid or !is_wood(items[i].type)) continue;
int dx = items[i].x - px; if(dx < 0) dx = -dx;
int dy = items[i].y - py; if(dy < 0) dy = -dy;
if(dx <= radius and dy <= radius)
{
int iid = items[i].id;
picked_type = items[i].type;
items.remove_at(i);
players[pindex].inv.give(picked_type, 1); // store the actual size so the I readout can break it down
got++;
for(uint m=0; m<players.length(); m++)
if(players[m].room_id == rid) send(players[m].peer_id, "removeitem "+iid, 0, true);
}
}
if(got > 0)
{
players[pindex].wood_collected += got; // running tally of ground pickups this game run, reported at game over
send(players[pindex].peer_id, "play_item "+picked_type+" take", 0, true);
// Let others in the game hear the pickup in 3D at the gatherer's spot (reuses the positional footstep relay).
for(uint wm=0; wm<players.length(); wm++)
if(players[wm].room_id == rid and players[wm].peer_id != players[pindex].peer_id)
send(players[wm].peer_id, "footstep equipment/items/wood/"+picked_type+"/take "+px+" "+py, 0, true);
send_wood_count(pindex);
}
}
/* Pick up every ammo item within `radius` tiles of the player -- the attacker's mirror of gather_wood. Only the
attacking side gathers ammo (EVP players, PVP attackers); PVE has none and defenders gather wood, not ammo. Adds
to the reserve (inventory), removes the items for everyone, and gives the picker the take sound + an ammo count. */
void gather_ammo(int pindex, int radius)
{
int rid = players[pindex].room_id;
int gi = get_game_index(rid);
if(gi < 0) return;
bool attacker = (games[gi].mode=="evp") or (games[gi].mode=="pvp" and players[pindex].team=="attack");
if(!attacker) return; // only the attacking side has ammo
if(games[gi].phase != "build" and games[gi].phase != "wave") return;
int px = players[pindex].x;
int py = players[pindex].y;
int got = 0;
string picked_type = "arrow"; // the type of a picked round, so the take sound matches (fallback never used when got>0)
for(int i=int(items.length())-1; i>=0; i--)
{
if(@items[i]==null) continue;
if(items[i].room_id != rid or !is_ammo(items[i].type)) continue;
int dx = items[i].x - px; if(dx < 0) dx = -dx;
int dy = items[i].y - py; if(dy < 0) dy = -dy;
if(dx <= radius and dy <= radius)
{
int iid = items[i].id;
picked_type = items[i].type;
items.remove_at(i);
players[pindex].inv.give(picked_type, 1); // add the round to the player's reserve
got++;
for(uint m=0; m<players.length(); m++)
if(players[m].room_id == rid) send(players[m].peer_id, "removeitem "+iid, 0, true);
}
}
if(got > 0)
{
send(players[pindex].peer_id, "play_item "+picked_type+" take", 0, true);
for(uint wm=0; wm<players.length(); wm++)
if(players[wm].room_id == rid and players[wm].peer_id != players[pindex].peer_id)
send(players[wm].peer_id, "footstep equipment/items/ammo/"+picked_type+"/take "+px+" "+py, 0, true);
send_ammo_count(pindex);
}
}
void netloop()
{
event = net.request();
if(writetimer.elapsed>writetime)
{
writetimer.restart();
writeprefs();
}
if(restart_pending and restart_timer.elapsed>=restart_delay)
{
restart_pending=false;
do_restart();
}
int64 nowmute = now_epoch();
array<string> pollchans = mute_channels_for("all");
for(uint i=0; i<players.length(); i++)
{
array<string> expired;
for(uint c=0; c<pollchans.length(); c++)
{
int64 u = get_player_mute(int(i), pollchans[c]);
if(u > 0 and nowmute >= u)
{
set_player_mute(int(i), pollchans[c], -1);
clear_channel_mute(players[i].name, pollchans[c]);
expired.insert_last(pollchans[c]);
}
}
if(expired.length() == 0) continue;
if(expired.length() == pollchans.length())
{
// Every channel expired together (a timed "all" mute) — announce it as one line, not four.
notify_target_mute(int(i), "all", false, 0);
announce_mute_to_others(display_name(int(i)), players[i].peer_id, "all", false);
}
else
{
for(uint e=0; e<expired.length(); e++)
{
notify_target_mute(int(i), expired[e], false, 0);
announce_mute_to_others(display_name(int(i)), players[i].peer_id, expired[e], false);
}
}
}
// Expire pending invitations (room or game): once one passes invite_timeout, clear it and tell the invited player.
for(uint i=0; i<players.length(); i++)
{
if((players[i].invite_room != 0 or players[i].invite_game != 0) and players[i].invite_timer.elapsed >= invite_timeout)
{
players[i].invite_room = 0;
players[i].invite_game = 0;
players[i].invite_from = "";
send(players[i].peer_id, "invitexpired", 0, true);
}
}
/* Expire held (disconnected-but-holding) sessions: once the grace window passes with no reconnect, run the real
teardown now. Their peer_id is the negative sentinel, which is exactly what members[]/host_peer hold, so the
disconnect handlers find and remove them correctly. They were already announced offline at hold time, so no
second offline notice here. */
for(int i=int(players.length())-1; i>=0; i--)
{
if(!players[i].held or players[i].held_timer.elapsed < reconnect_grace_ms) continue;
int sp=players[i].peer_id;
handle_disconnect_games(sp);
handle_disconnect_rooms(sp);
int idx=get_player_index(sp); // re-find: the handlers close rooms/games but don't remove the roster entry
if(idx>-1) players.remove_at(idx);
}
if(key_pressed(KEY_ESCAPE))
{
/* Escape is the deliberate "shut the server down" key. On a compiled build the hidden downcheck supervisor
would just relaunch us, so kill it FIRST (and wait until it's gone, so it can't relaunch in the gap) before
we exit -- restoring Escape's old close-for-good behavior. /restart and crashes don't do this, so they still
self-recover. Only one server (and one downcheck) can run per machine, so /IM can't hit anything else; if
downcheck isn't running, taskkill just no-ops. */
if(SCRIPT_COMPILED) run(expand_environment_variables("%SystemRoot%\\System32\\taskkill.exe"), "/F /IM downcheck.exe", true, true);
exit();
}
if(event.type==event_disconnect)
{
int dindex=get_player_index(event.peer_id);
if(dindex>-1 and has_restorable_state(dindex))
{
/* They were in a room/game/watching or host something: hold the slot for the grace window instead of
tearing down now. begin_hold announces them offline, strips their presence, and swaps their peer id for
a sentinel. The netloop poll below tears it down for real if they don't reconnect in time. */
begin_hold(dindex);
}
else
{
// A bare lobby session (or a peer that never spawned): nothing to restore, so tear down immediately.
handle_disconnect_games(event.peer_id);
handle_disconnect_rooms(event.peer_id);
int index=get_player_index(event.peer_id);
if(index>-1)
{
send(0, "offline "+players[index].name+" "+players[index].rank+" "+players[index].nickname, 0,true);
players.remove_at(index);
}
verified_logins.delete(""+event.peer_id); // forget this peer's authenticated identity so a recycled peer id can't inherit it
}
}
if(event.type==event_receive and event.channel==0)
{
string message=get_event_message();
string[] parsed=string_split(message, " ", true);
int index=get_player_index(event.peer_id);
if(parsed.length()==0)
{
/* empty or malformed packet: an empty decrypted message splits to a zero-length array, so bail before any
parsed[0] branch below can index past the end and crash the whole server loop. */
}
else if(world_frozen and !(parsed[0]=="login" or parsed[0]=="register" or parsed[0]=="spawn_player" or parsed[0]=="welcome" or parsed[0]=="frozennotice" or (index>-1 and rank_level(players[index].rank)>=3 and (parsed[0]=="freeze" or parsed[0]=="unfreeze"))))
{
/* Developer world-stop: while the game is frozen the server ignores every channel-0 message except a
developer's freeze/unfreeze and the login/spawn handshake (so a player can still connect and be frozen on
arrival). This is the authoritative lockout -- movement, pings, and every other command are dead, even to a
modified client, until a developer lifts the freeze. */
}
else if(message=="ping_request")
{
send(event.peer_id, "ping_response", 0, true);
}
else if(parsed[0]=="/getmotd")
{
send(event.peer_id, "Message of the Day: " + motd, 0, true);
}
else if(message=="/serveruptime")
{
int uptime_seconds = svruptimer.elapsed / 1000;
string uptime_message = format_uptime(uptime_seconds);
if(peak_players > 0) uptime_message += " Peak of " + peak_players + (peak_players == 1 ? " player" : " players") + ", on " + peak_when + ".";
send(event.peer_id, uptime_message, 0, true);
}
else if(parsed[0]=="login" and parsed.length()>3)
{
/* login is exactly "login <name> <password> <version>"; extra tokens mean a space slipped into the name
or password (the client forms block this, but a non-standard client could still send it), which would
verify a truncated credential -- reject it so a space never causes a failed login or unloggable account. */
if(parsed.length()>4) send(event.peer_id, "error: usernames and passwords cannot contain spaces.", 0,true);
else login(parsed[1], parsed[2], parsed[3]);
}
else if(parsed[0]=="register" and parsed.length()>3)
{
/* register is exactly "register <name> <email> <password>"; extra tokens mean a space in one of them,
which would silently truncate the stored value and make the account impossible to log into. */
if(parsed.length()>4) send(event.peer_id, "error: usernames, emails, and passwords cannot contain spaces.", 0,true);
else register_account(parsed[1], parsed[2], parsed[3]);
}
else if(parsed[0]=="spawn_player" and parsed.length()>2)
{
/* A peer may seat itself ONLY as the account it authenticated as in login() -- never the name the client
sends in the packet. This closes the bypass where a peer could skip login (or log in as a throwaway) and
spawn as any account, inheriting its rank (including the owner's forced developer). */
string vname;
if(!verified_logins.get(""+event.peer_id, vname))
{
send(event.peer_id, "error: you must log in before spawning.", 0,true);
}
else
{
int existing=-1;
for(uint i=0; i<players.length(); i++)
if(players[i].name==vname){ existing=int(i); break; }
if(existing>-1 and players[existing].restoring and players[existing].peer_id==event.peer_id)
{
/* Reconnect restore: login() already adopted the held session (peer rebound, hold cleared). Don't create a
new player or reset any state -- announce them back online and put them back into their room/game/watch
scope with inventory and host status intact. The in-memory channel mutes are preserved on the held session
and stay enforced; we deliberately DON'T re-announce them (no message or sound) on reconnect. */
players[existing].restoring=false;
index=existing;
send(event.peer_id, "yourrank "+players[index].rank, 0,true);
if(players[index].restore_reannounce) send(0, "online "+players[index].name+" "+players[index].rank+" "+players[index].nickname, 0,true); // only if they were held (announced offline); a live takeover was never offline
players[index].restore_reannounce=false;
send(event.peer_id, "voicemutestate "+(is_muted_now(index, "voice") ? "1" : "0"), 0, true); // silent voice-mute state so the client can warn on O without opening the mic; no message or sound
send_yourrooms(event.peer_id, players[index].name);
restore_scope(index);
update_peak(); // a reconnect can set a new high if others joined while this player was held
if(world_frozen) send(event.peer_id, "worldfreeze\nThe game is currently frozen.", 0, true); // reconnected during a developer world-stop: freeze them on arrival
}
else if(existing<0)
{
spawn_player(event.peer_id, vname, string_to_number(parsed[2]));
index=get_player_index(event.peer_id);
players[index].rank=get_rank(players[index].name);
if(is_owner(players[index].name) and players[index].rank != "developer")
{
// The owner account is always developer; fix an existing account that was created before/below that.
set_rank(players[index].name, "developer");
players[index].rank = "developer";
}
players[index].flagged = get_flag(players[index].name); // staff-attention flag, default off (incognito)
players[index].nickname = get_nickname(players[index].name); // display name (nickname.usr), defaults to the username
string lang = get_language(players[index].name); // language channel (language.usr); fall back to English if it's not a configured channel
players[index].language = is_valid_language(lang) ? lang : "English";
string pron = get_pronoun(players[index].name); // pronoun set (pronoun.usr); fall back to the they/them option if it's not a configured one
players[index].pronoun = is_valid_pronoun(pron) ? pron : default_pronoun();
players[index].ignored = get_ignored(players[index].name); // personal ignore list (ignored.usr): whose chat/voice this player drops
players[index].agreed = has_agreed_rules(players[index].name); // rules agreement (rules.usr vs rulesver); gates play until agreed. The reminder to read/agree is shown when they try to open the lobby, not at spawn.
send(event.peer_id, "yourrank "+players[index].rank, 0,true);
/* New accounts are announced at creation time (see register_account), so logging in for the first time
is just a normal "online" notice like anyone else. */
send(0, "online "+players[index].name+" "+players[index].rank+" "+players[index].nickname, 0,true);
update_peak(); // a player joined -- bump the all-time concurrent-player record if this is a new high
/* Load each channel mute from disk so it's enforced, but DON'T notify the player: a mute set while they
were offline shouldn't greet them with a message and sound every time they sign in (staff can still see
it on the F6 card, and any attempt to chat in that channel is quietly refused as always). */
array<string> spchans = mute_channels_for("all");
for(uint sc=0; sc<spchans.length(); sc++)
{
int64 mu = get_channel_mute(players[index].name, spchans[sc]);
if(mu == 0) set_player_mute(index, spchans[sc], 0);
else if(mu > 0)
{
int64 nowsec = now_epoch();
if(nowsec >= mu) clear_channel_mute(players[index].name, spchans[sc]);
else set_player_mute(index, spchans[sc], mu);
}
}
send(event.peer_id, "voicemutestate "+(is_muted_now(index, "voice") ? "1" : "0"), 0, true); // silent voice-mute state so the client can warn on O without opening the mic; no message or sound
/* Recreate this host's saved rooms (recreate-on-login). They sit ready in the lobby's room list;
the player themselves stays in the lobby until they Join one. */
if(get_saved_public(players[index].name)) create_room(players[index].name, event.peer_id, false, "");
string savedpriv = get_saved_private(players[index].name);
if(savedpriv != "") create_room(players[index].name, event.peer_id, true, savedpriv);
send_yourrooms(event.peer_id, players[index].name);
// Tell everyone where the new player is, and tell the new player where everyone else is.
broadcast_pos(index);
for(uint i=0; i<players.length(); i++)
{
if(i==uint(index) or players[i].room_id!=players[index].room_id) continue;
send(event.peer_id, pos_msg(int(i)), 0,true);
}
deliver_offline_pms(index); // hand over any private messages left for them while they were offline
if(world_frozen) send(event.peer_id, "worldfreeze\nThe game is currently frozen.", 0, true); // joined during a developer world-stop: freeze them on arrival (no fresh "X has frozen" line -- that already happened)
}
}
}
else if(parsed[0]=="move" and parsed.length()>2 and index>-1)
{
players[index].x=string_to_number(parsed[1]);
players[index].y=string_to_number(parsed[2]);
broadcast_pos(index); // no-op for spectators (guarded), so watchers aren't tracked as players
if(!players[index].spectating) { gather_wood(index, 5); gather_ammo(index, 5); } // auto-grab nearby wood (defenders) and ammo (attackers); each self-gates by role, and a watcher picks up neither
}
else if(parsed[0]=="voicecue" and index>-1 and parsed.length()==2 and (parsed[1]=="on" or parsed[1]=="off"))
{
/* Relay a speaker's voice on/off cue (von/voff) to everyone sharing their space, positioned at the speaker, so
others hear the mic key in 3D like the voice itself. Same routing as the channel-3 voice relay: same room,
skip self, skip a listener who ignores the speaker. A voice-muted player can't talk, so send no cue. */
if(!is_muted_now(index, "voice"))
{
string cue="voicecue "+players[index].name+" "+players[index].x+" "+players[index].y+" "+parsed[1];
for(uint i=0; i<players.length(); i++)
{
if(players[i].peer_id==event.peer_id or players[i].room_id!=players[index].room_id) continue;
if(player_ignores(int(i), players[index].name)) continue; // listener has the speaker on their personal ignore list
send(players[i].peer_id, cue, 0, true);
}
}
}
else if(parsed[0]=="setweapon" and index>-1 and parsed.length()>1)
{
/* The attacker's client tells us which weapon it just drew, so we can restore the same one on a reconnect.
Validate against the loaded weapons; ignore anything else. On the FIRST time this round the player draws a RANGED
weapon of a given ammo kind, grant that kind's starter RESERVE (Option A -- so the melee auto-arm at round start
doesn't block it), and on each ranged weapon's first draw fill its OWN magazine. Magazines are PER WEAPON, so the
pistol and machine gun share a normal-ammo reserve but never a mag. A melee weapon grants nothing. */
string w=parsed[1];
weapon_data@ wd = get_weapon_data(w);
if(wd !is null)
{
players[index].weapon=w;
if(!wd.melee and wd.ammo_type != "")
{
int gi = get_game_index(players[index].room_id);
bool attacker = gi>=0 and ((games[gi].mode=="evp") or (games[gi].mode=="pvp" and players[index].team=="attack"));
if(attacker and (games[gi].phase=="build" or games[gi].phase=="wave"))
{
if(players[index].granted_ammo_types.find(wd.ammo_type) < 0)
{
players[index].inv.give(wd.ammo_type, ammo_starter_amount(wd.ammo_type)); // starter reserve, once per ammo kind
players[index].granted_ammo_types.insert_last(wd.ammo_type);
send_ammo_count(index);
}
if(players[index].granted_mags.find(w) < 0)
{
players[index].mag.give(w, wd.max_ammo); // this weapon's own magazine starts full on its first draw of the round
players[index].granted_mags.insert_last(w);
}
}
}
// Tell the client the equipped weapon's stats (magazine size, tap cadence, current loaded, fire mode, auto cadence) for firing and the X readout.
if(wd.melee) send(players[index].peer_id, "weaponstats 0 0 0 0 0 0", 0, true);
else send(players[index].peer_id, "weaponstats 1 "+wd.max_ammo+" "+wd.spam_time+" "+players[index].mag.count(w)+" "+wd.fire_mode+" "+wd.repeat_time, 0, true);
}
}
else if(parsed[0]=="fire" and index>-1)
{
/* An attacker fired their ranged weapon ("fire <facing>"; the client already played the shot and decremented its
own view of the magazine optimistically). Ray-march from the shooter along their facing to the first wall within
range, then LOCK the outcome (5d, the A-plus model): a shot in a wave attack window at a wall in range with a
round chambered is DAMAGING -- spend one round and hold a bullet that hurts the wall on arrival; a shot during
build, a rest window, or that finds no wall is a free RICOCHET (no ammo spent, no damage, just the bounce). So
ammo is spent only when the shot can actually hurt the wall. resolve_bullets lands the hit/bounce when the travel
timer elapses; the authoritative magazine count goes back either way so the client's optimistic view re-syncs. */
int gi = get_game_index(players[index].room_id);
weapon_data@ fwd = get_weapon_data(players[index].weapon);
bool attacker = gi>=0 and ((games[gi].mode=="evp") or (games[gi].mode=="pvp" and players[index].team=="attack"));
bool armed = attacker and fwd !is null and !fwd.melee and fwd.ammo_type != "" and (games[gi].phase=="build" or games[gi].phase=="wave");
if(armed)
{
string face = (parsed.length()>1) ? parsed[1] : ""; // the direction the shooter faces: west/east/north/south
/* Ray-march one tile at a time along the facing, up to the weapon's range, to the first wall line. Border walls
(EVP/PVE) sit at 0 and size; the PVP ring sits at wmin/wmax and spans only wmin..wmax on its side, so a shot past
a corner finds no wall. tdir/tdist = the wall hit and its distance in tiles, or "" if nothing lies that way. */
int s = int(games[gi].size);
bool pvp = (games[gi].mode == "pvp");
int wmin = s/4, wmax = s - wmin;
int dx=0, dy=0;
if(face=="west") dx=-1; else if(face=="east") dx=1; else if(face=="north") dy=1; else if(face=="south") dy=-1;
string tdir=""; int tdist=0;
if(dx!=0 or dy!=0)
{
int cx=players[index].x, cy=players[index].y;
for(int d=1; d<=fwd.range_hi; d++)
{
cx+=dx; cy+=dy;
if(pvp)
{
if(dx<0 and cx==wmin and cy>=wmin and cy<=wmax) { tdir="west"; tdist=d; break; }
if(dx>0 and cx==wmax and cy>=wmin and cy<=wmax) { tdir="east"; tdist=d; break; }
if(dy>0 and cy==wmax and cx>=wmin and cx<=wmax) { tdir="north"; tdist=d; break; }
if(dy<0 and cy==wmin and cx>=wmin and cx<=wmax) { tdir="south"; tdist=d; break; }
}
else
{
if(dx<0 and cx==0) { tdir="west"; tdist=d; break; }
if(dx>0 and cx==s) { tdir="east"; tdist=d; break; }
if(dy>0 and cy==s) { tdir="north"; tdist=d; break; }
if(dy<0 and cy==0) { tdir="south"; tdist=d; break; }
}
}
}
bool window = (games[gi].phase=="wave" and games[gi].wave_attacking); // an attack window: a shot can hurt the wall
bool damaging = (tdir != "") and window;
if(damaging)
{
if(players[index].mag.count(players[index].weapon) > 0) players[index].mag.take(players[index].weapon, 1); // spend one round from THIS weapon's own magazine -- only on a shot that can hurt the wall
else damaging = false; // nothing chambered: it still flies, but as a harmless ricochet that spends nothing
}
if(tdir != "")
{
pending_bullet b;
b.shooter = players[index].name;
b.weapon = players[index].weapon;
b.dir = tdir;
b.damaging = damaging;
b.dmg_lo = fwd.dmg_lo; b.dmg_hi = fwd.dmg_hi;
b.flight_ms = tdist * fwd.bullet_speed; // distance to the wall (tiles) times the weapon's ms-per-tile speed
b.flight.restart();
games[gi].bullets.insert_last(b);
send_to_game(games[gi].id, "bulletspawn "+players[index].x+" "+players[index].y+" "+tdir+" "+players[index].weapon+" "+b.flight_ms); // clients play the travelling loop from the shooter to the wall
}
}
send(players[index].peer_id, "loaded "+((fwd is null) ? 0 : players[index].mag.count(players[index].weapon)), 0, true); // re-sync this weapon's magazine (unchanged for a free/whiffed shot, one less for a spent round)
}
else if(parsed[0]=="reload" and index>-1)
{
/* An attacker finished a reload (the client drove the timing off the reload sound). Move rounds from the reserve
into the magazine, up to max_ammo, and re-sync the client's loaded + reserve counts. Validated like fire. */
int gi = get_game_index(players[index].room_id);
weapon_data@ rwd = get_weapon_data(players[index].weapon);
bool attacker = gi>=0 and ((games[gi].mode=="evp") or (games[gi].mode=="pvp" and players[index].team=="attack"));
bool can = attacker and rwd !is null and !rwd.melee and rwd.ammo_type != "" and (games[gi].phase=="build" or games[gi].phase=="wave");
if(can)
{
int need = rwd.max_ammo - players[index].mag.count(players[index].weapon); // room left in THIS weapon's own magazine
int have = players[index].inv.count(rwd.ammo_type);                        // rounds in the shared per-kind reserve
int move = (need < have) ? need : have;
if(move > 0)
{
players[index].inv.take(rwd.ammo_type, move);        // out of the reserve
players[index].mag.give(players[index].weapon, move); // into this weapon's magazine
send_ammo_count(index);                              // the reserve changed
}
send(players[index].peer_id, "loaded "+players[index].mag.count(players[index].weapon), 0, true); // the new magazine count
}
}
else if(parsed[0]=="reinforce" and index>-1)
{
/* Shift+Enter near a wall: spend 1 wood for a random +10 to +20 strength on the NEAREST wall in reach.
Position-based (not facing-based), so it works from up to wall_reach tiles out in any direction. */
int gi = get_game_index(players[index].room_id);
if(gi < 0) {} // not in a game
else if(games[gi].phase != "build" and games[gi].phase != "wave") send(event.peer_id, "You can only reinforce during a round.", 0,true);
else if(games[gi].phase == "wave" and games[gi].wave_attacking) send(event.peer_id, games[gi].mode=="pvp" ? "You can't reinforce while the attackers are striking." : "You can't reinforce while the enemies are attacking.", 0,true);
else if(games[gi].mode=="pvp" and players[index].team != "defend") send(event.peer_id, "Only the defenders reinforce the walls.", 0,true);
else if(wood_total(players[index].inv) < 1) send(event.peer_id, "You don't have any wood.", 0,true);
else
{
string dir = (games[gi].mode=="pvp") ? ring_wall_in_reach_inside(players[index].x, players[index].y, games[gi].size) : wall_in_reach(players[index].x, players[index].y, games[gi].size); // PVP defenders reach the ring from inside
if(dir == "") send(event.peer_id, "You need to be near a wall.", 0,true);
else
{
int wi = wall_in_dir(games[gi].id, dir, games[gi].size); // ring wall in PVP, outer border otherwise
if(wi > -1 and walls[wi].health <= 0) send(event.peer_id, "That wall is destroyed.", 0,true);
else if(wi > -1)
{
/* A per-game reinforce cap is set and this wall is already at (or above) it: refuse BEFORE spending any wood,
rather than silently eating the piece for no gain. "No limit" (reinforce_cap 0) never refuses. */
if(games[gi].reinforce_cap > 0 and walls[wi].health >= walls[wi].maxhealth * games[gi].reinforce_cap) send(event.peer_id, "You can't reinforce this wall any further.", 0,true);
else
{
string place_type = spend_one_wood(players[index].inv); // spend your biggest piece first (large -> medium -> small)
int gain = wood_reinforce_value(place_type); // repair scales with the size spent (small<medium<large)
if(games[gi].reinforce_cap > 0) repair_wall(wi, gain, true, games[gi].reinforce_cap); // per-game reinforce limit (200/400/600/800% of full strength)
else repair_wall(wi, gain, false); // "No limit" was chosen: uncapped, as before
if(games[gi].mode=="pvp") players[index].pvp_wood_placed++; // tally this defender's placements for the results screen
send_wood_count(index);
/* Play the placement in 3D AT THE WALL being reinforced -- the placer's spot projected onto that border --
so everyone, the placer included, hears which wall and side the wood went to. Reuses the footstep relay. */
int placex = players[index].x, placey = players[index].y;
if(games[gi].mode=="pvp") // project onto the inset ring, not the outer border
{
int wm = games[gi].size/4;
if(dir=="west") placex = wm;
else if(dir=="east") placex = games[gi].size - wm;
else if(dir=="south") placey = wm;
else if(dir=="north") placey = games[gi].size - wm;
}
else if(dir=="west") placex = 0;
else if(dir=="east") placex = games[gi].size;
else if(dir=="south") placey = 0;
else if(dir=="north") placey = games[gi].size;
for(uint pm=0; pm<players.length(); pm++)
if(players[pm].room_id == players[index].room_id)
send(players[pm].peer_id, "footstep equipment/items/wood/"+place_type+"/place "+placex+" "+placey, 0, true);
send(event.peer_id, "reinforced "+dir+" "+gain, 0,true);
broadcast_wall_strength(games[gi].id);
}
}
}
}
}
else if(parsed[0]=="attack" and index>-1 and parsed.length()>1)
{
/* EVP: a player's swing landed (the client times the windup). Apply this weapon's damage to the NEAREST
wall in reach -- the mirror of reinforce -- then broadcast the strike so everyone hears the impact. A
swing with no wall in reach simply whiffs (no message, since the swing is a continuous held action). */
int gi = get_game_index(players[index].room_id);
if(gi < 0) {} // not in a game
else if(games[gi].mode == "pvp")
{
/* PVP (section 3): the attacking side swings at the ring walls for FEEDBACK only -- no damage yet (that's the
next section). Find the nearest ring wall in reach; during a wave's attack window the swing connects (wallhit),
otherwise (build/prep phase or a build window) it ricochets (wallrico). Defenders never attack walls. */
if(players[index].team == "attack" and (games[gi].phase == "build" or games[gi].phase == "wave"))
{
string dir = ring_wall_in_reach(players[index].x, players[index].y, games[gi].size);
if(dir != "") // a ring wall is in reach; otherwise the swing whiffs (silent)
{
int wi = ring_wall(games[gi].id, dir, games[gi].size);
if(wi > -1 and walls[wi].health > 0)
{
int wid = weapon_id_for_name(parsed[1]);
if(games[gi].phase == "wave" and games[gi].wave_attacking)
{
/* Attack window: the swing actually damages the wall (the weapon's tier, same table the bots use), then
everyone (and watchers) hears the strike. Unlike EVP there is no permanent-floor ratchet -- a STANDING
wall is fully repairable; only a wall demolished to 0 is permanent (it leaves impassable debris client-side). */
int dmg = enemy_damage(wid);
damage_wall(wi, dmg);
players[index].pvp_damage += dmg; // tally this attacker's total damage for the results screen
broadcast_wall_strength(games[gi].id);
send_to_game(games[gi].id, "wallhit "+dir+" "+wid);
if(walls[wi].health <= 0) send_to_game(games[gi].id, "walldestroyed "+dir); // downed -> the client re-tiles it to impassable debris (no bots to redistribute in PVP)
}
else send_to_game(games[gi].id, "wallrico "+dir+" "+wid); // build/prep or build window: it just ricochets
}
}
}
}
else if(games[gi].mode != "evp") {} // PVE players defend; they don't attack walls
else if(games[gi].phase != "build" and games[gi].phase != "wave") {} // only during a round
else
{
string dir = wall_in_reach(players[index].x, players[index].y, games[gi].size);
if(dir != "") // a wall is in reach; otherwise the swing whiffs (silent)
{
int wi = border_wall(games[gi].id, dir, games[gi].size);
if(wi > -1 and walls[wi].health > 0)
{
int wid = weapon_id_for_name(parsed[1]);
if(games[gi].phase == "wave" and games[gi].wave_attacking)
{
/* The wave's attack segment is on: the swing actually damages the wall, and everyone (and watchers) hear the
strike. Half of the hit (evp_permanent_fraction) is permanent -- it lowers the wall's repair ceiling, so the
builders can claw the rest back during a rest window but never the whole hit, and the attackers always gain ground. */
int dmg = enemy_damage(wid);
damage_wall(wi, dmg);
lower_wall_floor(wi, dmg * evp_permanent_fraction);
broadcast_wall_strength(games[gi].id);
send_to_game(games[gi].id, "wallhit "+dir+" "+wid); // EVP plays it at constant volume
if(walls[wi].health <= 0) on_wall_destroyed(games[gi].id, gi, dir);
}
else
{
/* Build phase or a rest segment: the wall can't be hurt right now (the bots are repairing), so the swing
just ricochets -- the weapon's hit clip plays (no damage) so everyone (and watchers) hears the swing connect. */
send_to_game(games[gi].id, "wallrico "+dir+" "+wid);
}
}
}
}
}
else if(parsed[0]=="step" and parsed.length()>3 and index>-1)
{
/* Relay a footstep/wall-bump sound to everyone sharing the stepper's room, so they hear the move. A
spectator's own steps are NOT relayed -- watchers move unheard by the players below. */
if(!players[index].spectating)
{
string fs="footstep "+parsed[1]+" "+parsed[2]+" "+parsed[3];
for(uint i=0; i<players.length(); i++)
if(players[i].room_id==players[index].room_id and players[i].peer_id!=event.peer_id) send(players[i].peer_id, fs, 0, true);
}
}
else if(parsed[0]=="disconnect")
{
if(index>-1)
{
send(0, "offline "+players[index].name+" "+players[index].rank+" "+players[index].nickname, 0,true);
send(players[index].peer_id, "terminate", 0,true);
handle_disconnect_games(event.peer_id);
handle_disconnect_rooms(event.peer_id); // close any rooms they host now, not a beat later when enet drops them.
players.remove_at(index);
}
}
else if(parsed[0]=="welcome" and index>-1)
{
send(event.peer_id, "play welcome.ogg", 0,true);
send(event.peer_id, "welcome to the CaveDefender server. server version "+version, 0,true);
}
else if(parsed[0]=="who" and index>-1)
{
string[] names;
for(uint i=0; i<players.length(); i++)
{
if(players[i].held) continue; // held sessions read as offline (already announced offline), so keep /who consistent
string we = afk_prefix(i)+display_name(i);
if(string_to_lower_case(players[i].nickname) != string_to_lower_case(players[i].name)) we += " ("+players[i].name+")"; // show the real username so staff can target it
names.insert_last(we);
}
send(event.peer_id, roster_sentence("on the server", names), 0,true);
}
else if(parsed[0]=="playerlist" and index>-1)
{
push_player_list(index); // F6: the server-wide roster as a navigable menu (same set as /who)
}
else if(parsed[0]=="ignoremenu" and index>-1) push_ignore_menu(index); // /ignore: pick an online player to personally mute
else if(parsed[0]=="ignoredmenu" and index>-1) push_ignored_menu(index); // /ignored: review and unmute your personal ignore list
else if(parsed[0]=="ignore" and index>-1 and parsed.length()>1)
{
/* Personal mute from the F6 info card: add a username to this player's ignore list (their chat and voice
stop reaching this player). The target isn't notified when muted, but a PM to this player will tell them
they've been muted. Can't ignore yourself, and can't mute staff (they're never personally muteable). */
string tu = parsed[1];
if(string_to_lower_case(tu) != string_to_lower_case(players[index].name) and account_exists(tu) and !is_staff(get_rank(tu)) and !player_ignores(index, tu)) // staff can never be personally muted
{
players[index].ignored.insert_last(tu);
set_ignored(players[index].name, players[index].ignored); // persist to ignored.usr
}
}
else if(parsed[0]=="unignore" and index>-1 and parsed.length()>1)
{
// Lift a personal mute: drop a username from this player's ignore list (case-insensitive) and persist.
string tu = parsed[1];
for(int k=int(players[index].ignored.length())-1; k>=0; k--)
if(string_to_lower_case(players[index].ignored[k]) == string_to_lower_case(tu)) players[index].ignored.remove_at(k);
set_ignored(players[index].name, players[index].ignored);
}
else if(parsed[0]=="staff" and index>-1)
{
send(event.peer_id, "stafflist "+build_staff_list(), 0,true);
}
else if(parsed[0]=="channel" and index>-1)
{
push_language_menu(index); // the /channel chooser, available to everyone
}
else if(parsed[0]=="pronoun" and index>-1)
{
push_pronoun_menu(index); // the /pronoun chooser, available to everyone
}
else if(parsed[0]=="acceptinvite" and index>-1)
{
if(!players[index].agreed) send(event.peer_id, "misc You must agree to the server rules before you can play; type /rules to read them, then /rules agree.", 0,true);
else accept_invite(index); // /accept: join the room you were invited to
}
else if(parsed[0]=="rejectinvite" and index>-1)
{
if(!players[index].agreed) send(event.peer_id, "misc You must agree to the server rules before you can play; type /rules to read them, then /rules agree.", 0,true);
else reject_invite(index); // /reject: refuse the pending room invite
}
else if(parsed[0]=="afk" and index>-1)
{
// The client's self-AFK countdown finished: mark this player away and tell everyone (flag-aware name).
if(!players[index].afk)
{
players[index].afk=true;
/* Optional reason typed with /afk, announced once and stored nowhere. It's broadcast to every player across
channels (like local chat), so it always gets both filters; a reason that fails is dropped and the player is
told, but still goes AFK (they already sat through the countdown -- no point punishing them for one word). */
string reason = (parsed.length() > 1) ? string_join(parsed, " ", 1, parsed.length()).trim_whitespace() : "";
bool afk_reason_dropped = (reason != "" and (filter_crash(reason) or filter_chat(reason)));
if(afk_reason_dropped) reason = "";
string disp=display_name_flagged(index);
send(event.peer_id, "afkself 1\n"+reason, 0, true); // you: first-person misc + cue, with any reason
for(uint ai=0; ai<players.length(); ai++) if(int(players[ai].peer_id)!=event.peer_id) send(players[ai].peer_id, "afkannounce 1\n"+disp+"\n"+reason, 0,true); // others: player events + cue, with any reason
broadcast_pos(index); // refresh the AFK marker in everyone's player tracker
if(afk_reason_dropped) send(event.peer_id, "misc Your away reason contained forbidden words, so you went away without it.", 0, true);
}
}
else if(parsed[0]=="afkreturn" and index>-1)
{
// Any input on the client brought them back: clear AFK and announce the return.
if(players[index].afk)
{
players[index].afk=false;
string disp=display_name_flagged(index);
send(event.peer_id, "afkself 0", 0, true);
for(uint ai=0; ai<players.length(); ai++) if(int(players[ai].peer_id)!=event.peer_id) send(players[ai].peer_id, "afkannounce 0\n"+disp, 0,true);
broadcast_pos(index);
}
}
else if(parsed[0]=="staffchat" and index>-1 and is_staff(players[index].rank) and parsed.length()>1)
{
string msg=string_join(parsed, " ", 1, parsed.length());
if(filter_crash(msg)) send(event.peer_id, "misc Your message contains forbidden words, and therefore will not be sent.", 0,true); // crash-string protection applies to staff chat too
else relay_to_staff("staffmsg "+afk_prefix(index)+display_name(index)+": "+msg);
}
else if(parsed[0]=="staffme" and index>-1 and is_staff(players[index].rank) and parsed.length()>1)
{
string action=string_join(parsed, " ", 1, parsed.length());
if(filter_crash(action)) send(event.peer_id, "misc Your message contains forbidden words, and therefore will not be sent.", 0,true); // crash-string protection applies to staff chat too
else relay_to_staff("staffmsg "+afk_prefix(index)+display_name(index)+" "+action);
}
else if(parsed[0]=="localchat" and index>-1 and parsed.length()>1)
{
string msg=string_join(parsed, " ", 1, parsed.length());
if(is_muted_now(index, "local")) send(event.peer_id, muted_chat_message(index, "local"), 0,true);
else if(filter_crash(msg) or filter_chat(msg)) send(event.peer_id, "misc Your message contains forbidden words, and therefore will not be sent.", 0,true); // local chat is always filtered (crash strings + word filter), regardless of language channel
else relay_to_local(players[index].room_id, "localmsg "+afk_prefix(index)+display_name_flagged(index)+": "+msg, "", index); // local chat reaches everyone in the space, regardless of language channel (minus anyone ignoring the sender)
}
else if(parsed[0]=="localme" and index>-1 and parsed.length()>1)
{
string action=string_join(parsed, " ", 1, parsed.length());
if(is_muted_now(index, "local")) send(event.peer_id, muted_chat_message(index, "local"), 0,true);
else if(filter_crash(action) or filter_chat(action)) send(event.peer_id, "misc Your message contains forbidden words, and therefore will not be sent.", 0,true); // local chat is always filtered (crash strings + word filter), regardless of language channel
else relay_to_local(players[index].room_id, "localmsg "+afk_prefix(index)+display_name_flagged(index)+" "+action, "", index); // local chat reaches everyone in the space, regardless of language channel (minus anyone ignoring the sender)
}
else if(parsed[0]=="teamchat" and index>-1 and parsed.length()>1)
{
string msg=string_join(parsed, " ", 1, parsed.length());
if(get_game_index(players[index].room_id) < 0 or games[get_game_index(players[index].room_id)].mode != "pvp") send(event.peer_id, "Team chat is only available in player versus player games.", 0,true);
else if(is_muted_now(index, "team")) send(event.peer_id, muted_chat_message(index, "team"), 0,true);
else if(filter_crash(msg) or filter_chat(msg)) send(event.peer_id, "misc Your message contains forbidden words, and therefore will not be sent.", 0,true); // team chat is filtered like local (crash strings + word filter)
else relay_to_team(index, "teammsg "+afk_prefix(index)+display_name_flagged(index)+": "+msg);
}
else if(parsed[0]=="teamme" and index>-1 and parsed.length()>1)
{
string action=string_join(parsed, " ", 1, parsed.length());
if(get_game_index(players[index].room_id) < 0 or games[get_game_index(players[index].room_id)].mode != "pvp") send(event.peer_id, "Team chat is only available in player versus player games.", 0,true);
else if(is_muted_now(index, "team")) send(event.peer_id, muted_chat_message(index, "team"), 0,true);
else if(filter_crash(action) or filter_chat(action)) send(event.peer_id, "misc Your message contains forbidden words, and therefore will not be sent.", 0,true);
else relay_to_team(index, "teammsg "+afk_prefix(index)+display_name_flagged(index)+" "+action);
}
else if(parsed[0]=="help" and index>-1 and parsed.length()>1)
{
string which=string_to_lower_case(parsed[1]);
if(which!="player" and which!="staff")
{
send(event.peer_id, "No help page named "+parsed[1]+". Try player or staff.", 0,true);
}
else if(which=="staff" and rank_level(players[index].rank)<1)
{
// Staff help is staff-only; a non-staff request is silently ignored.
}
else if(!file_exists("docks/help/"+which+".txt"))
{
send(event.peer_id, "The "+which+" help page is missing on the server.", 0,true);
}
else
{
file hf;
hf.open("docks/help/"+which+".txt", "rb");
string content=hf.read();
hf.close();
send(event.peer_id, "helptext "+which+"\n"+content, 0,true);
}
}
else if(parsed[0]=="rules" and index>-1 and parsed.length()>1)
{
string which=string_to_lower_case(parsed[1]);
/* "agree"/"disagree" are the rules-gate answers, not pages. Agreeing requires having read the required
pages first: everyone must read the PLAYER rules, and staff must also read the STAFF rules.
Disagreeing drops the player back to the connection menu. Both are open to everyone. */
if(which=="agree")
{
if(players[index].agreed) send(event.peer_id, "misc You already agreed to the server rules.", 0,true);
else if(!players[index].read_player_rules) send(event.peer_id, "misc Please read the player rules first with /rules, then type /rules agree.", 0,true);
else if(is_staff(players[index].rank) and !players[index].read_staff_rules) send(event.peer_id, "misc As a staff member you must also read the staff rules with /rules staff before you can agree.", 0,true);
else
{
players[index].agreed=true;
set_agreed_rules(players[index].name); // persist the current rulesver to rules.usr
send(event.peer_id, "agreedrules", 0,true); // client clears the prompt and confirms
}
}
else if(which=="disagree")
{
// Already agreed players can't un-agree by disagreeing: treat it like the agree case and just remind them.
if(players[index].agreed) { send(event.peer_id, "misc You already agreed to the server rules.", 0,true); }
else
{
// They declined: tell the client (which returns to the connection menu) and drop them, like a normal disconnect.
send(event.peer_id, "declinedrules", 0,true);
send(0, "offline "+players[index].name+" "+players[index].rank+" "+players[index].nickname, 0,true);
players.remove_at(index);
verified_logins.delete(""+event.peer_id);
}
}
/* Both rules pages are open to everyone (unlike the staff help): players can read the staff rules too, so they
can see the standards staff are held to and hold them accountable. */
else if(which!="player" and which!="staff")
{
send(event.peer_id, "No rules page named "+parsed[1]+". Try player or staff.", 0,true);
}
else if(!file_exists("docks/rules/"+which+".txt"))
{
send(event.peer_id, "The "+which+" rules page is missing on the server.", 0,true);
}
/* A regular player must read their own (player) rules before they're allowed to peek at the staff rules;
staff can read either page in any order. */
else if(which=="staff" and !is_staff(players[index].rank) and !players[index].read_player_rules)
{
send(event.peer_id, "misc Please read the player rules first with /rules, then you can read the staff rules.", 0,true);
}
else
{
if(which=="player") players[index].read_player_rules=true; // remember which page they've read, for the agree gate
else players[index].read_staff_rules=true;
file rf;
rf.open("docks/rules/"+which+".txt", "rb");
string content=rf.read();
rf.close();
send(event.peer_id, "rulestext "+which+"\n"+content, 0,true);
}
}
else if(parsed[0]=="where" and index>-1 and parsed.length()>1)
{
/* Everyone: report where an ONLINE player is, using the same phrase the F6 card shows, named for the target
(e.g. "Bob is in the lobby."). Resolves by username or nickname; offline/unknown gets the usual not-found line. */
int ti = get_player_index_from(parsed[1]);
if(ti < 0) reply_target_not_found(event.peer_id, parsed[1]);
else if(player_ignores(ti, players[index].name)) send(event.peer_id, "misc This player's location is private.", 0, true); // they've personally muted you, so you can't look up their whereabouts (staff are exempt via player_ignores)
else
{
string loc = player_location_phrase(ti); // "In the lobby." / "In X's room." / "Watching X's game."
send(event.peer_id, "misc "+display_name(ti)+" is "+string_to_lower_case(loc.substr(0,1))+loc.substr(1), 0, true);
}
}
else if(parsed[0]=="changepassself" and index>-1 and parsed.length()==3)
{
/* Self /changepass: verify the CURRENT password, then store the new Argon2id hash and log the player out so they
re-sign-in with it (the client knows the new password and updates its saved account). Passwords never ride chat. */
string cur = parsed[1];
string np = parsed[2];
if(!verify_password(players[index].name, cur)) send(event.peer_id, "misc Your current password is incorrect.", 0, true);
else if(np.length() < 6 or np.length() > 24) send(event.peer_id, "misc Your new password must be between 6 and 24 characters.", 0, true);
else
{
write_field(players[index].name, "password", password_blob(make_salt(), np));
int tpeer = players[index].peer_id;
send(0, "offline "+players[index].name+" "+players[index].rank+" "+players[index].nickname, 0, true); // announce them offline now
send(tpeer, "passchanged", 0, true); // the client updates its saved password and returns to the connection menu
players.remove_at(index); // free the slot now so the ensuing disconnect doesn't hold it; disconnect cleans up rooms/games/verified_logins
}
}
else if(parsed[0]=="changepassadmin" and index>-1 and parsed.length()==3)
{
/* Admin RESET: administrator+ sets another online player's password without their old one (at-or-below rank), then
logs them out. Their saved password is left stale (they don't know the new one), so staff tell them out of band. */
if(rank_level(players[index].rank) < 2) send(event.peer_id, "misc You can't reset another player's password.", 0, true);
else
{
int ti = get_player_index_from(parsed[1]);
string np = parsed[2];
if(ti < 0) reply_target_not_found(event.peer_id, parsed[1]);
else if(rank_level(players[ti].rank) > rank_level(players[index].rank)) send(event.peer_id, "misc You can't reset the password of someone above your rank.", 0, true);
else if(np.length() < 6 or np.length() > 24) send(event.peer_id, "misc The new password must be between 6 and 24 characters.", 0, true);
else
{
write_field(players[ti].name, "password", password_blob(make_salt(), np));
int tpeer = players[ti].peer_id;
send(event.peer_id, "misc You reset "+display_name_flagged(ti)+"'s password.", 0, true);
notify_staff_audit(afk_prefix(index)+display_name_flagged(index)+" reset "+afk_prefix(ti)+display_name_flagged(ti)+"'s password.", -1);
send(0, "offline "+players[ti].name+" "+players[ti].rank+" "+players[ti].nickname, 0, true);
send(tpeer, "passreset", 0, true); // the target is logged out; their saved password stays as-is
players.remove_at(ti);
}
}
}
else if(parsed[0]=="delcharself" and index>-1 and parsed.length()==2)
{
/* Self /delchar: verify the player's OWN password, then delete their account, announce it, and log them out. The
owner may delete itself (delete_account drops that alias from conf.svr's owners list). Departure is announced by the deletion notice,
not a plain "offline" line, so remove from the roster before broadcasting so this player is naturally skipped. */
string pw = parsed[1];
if(!verify_password(players[index].name, pw)) send(event.peer_id, "misc Incorrect password.", 0, true);
else
{
string acct = players[index].name;
int tpeer = players[index].peer_id;
string dname = afk_prefix(index) + display_name_flagged(index); // flag/AFK/nickname-aware, captured before removal
if(!delete_account(acct)) send(event.peer_id, "misc The deletion failed, so your account was not removed.", 0, true);
else
{
remove_from_online_ignores(acct);
players.remove_at(index);
for(uint i=0; i<players.length(); i++) send(players[i].peer_id, "chardeleted "+dname+" has deleted their account.", 0, true);
send(tpeer, "delchardone", 0, true);
}
}
}
else if(parsed[0]=="delcharadmin" and index>-1 and parsed.length()==2)
{
/* Admin /delchar <username>: administrator+ deletes another ONLINE player's account (at-or-below rank). The owner
can't be deleted by anyone else (use the self form); self-targeting is bounced to the password-checked self form. */
if(rank_level(players[index].rank) < 2) send(event.peer_id, "misc You can't delete other players' accounts.", 0, true);
else
{
int ti = get_player_index_from(parsed[1]);
if(ti < 0) reply_target_not_found(event.peer_id, parsed[1]);
else if(ti == index) send(event.peer_id, "misc To delete your own account, use /delchar with no name.", 0, true);
else if(is_owner(players[ti].name)) send(event.peer_id, "misc You can't delete the owner's account.", 0, true);
else if(rank_level(players[ti].rank) > rank_level(players[index].rank)) send(event.peer_id, "misc You can't delete the account of someone above your rank.", 0, true);
else
{
string acct = players[ti].name;
int tpeer = players[ti].peer_id;
string tflagged = display_name_flagged(ti);
string dname = afk_prefix(ti) + tflagged; // the target, for the public + audit lines
string aname = afk_prefix(index) + display_name_flagged(index); // the actor, captured before any removal shifts indices
if(!delete_account(acct)) send(event.peer_id, "misc The deletion failed, so the account was not removed.", 0, true);
else
{
remove_from_online_ignores(acct);
players.remove_at(ti);
send(event.peer_id, "misc You deleted "+tflagged+"'s account.", 0, true);
notify_staff_audit(aname+" deleted "+dname+"'s account.", -1);
for(uint i=0; i<players.length(); i++) send(players[i].peer_id, "chardeleted "+dname+"'s account has been deleted.", 0, true);
send(tpeer, "delcharkicked", 0, true);
}
}
}
}
else if(parsed[0]=="getwarnings" and index>-1 and parsed.length()>1)
{
/* Staff (moderator+) view a player's saved warning history, read-only, in the client's doc viewer. Accepts a
username OR (for an online player) a nickname: resolve an online player first, else treat it as a username for
an offline account (warnings live on disk, like /unban). Non-staff is silently ignored. */
if(rank_level(players[index].rank) < 1) { }
else
{
int ti = get_player_index_from(parsed[1]); // online player by username or nickname
string target = (ti > -1) ? players[ti].name : parsed[1]; // resolve to the account username (the warnings key)
if(!account_exists(target)) send(event.peer_id, "misc This player does not exist.", 0, true);
else
{
string uname = read_field(target, "username", target); // canonical-case username for the viewer title
send(event.peer_id, "warnstext "+uname+"\n"+format_warnings(target), 0, true);
}
}
}
else if(parsed[0]=="getbans" and index>-1 and parsed.length()>1)
{
/* Staff (moderator+) view a player's ban status, read-only, in the doc viewer. Same targeting as /warnings:
an online player by username or nickname, else a username for an offline account (bans live on disk). */
if(rank_level(players[index].rank) < 1) { }
else
{
int ti = get_player_index_from(parsed[1]);
string target = (ti > -1) ? players[ti].name : parsed[1];
if(!account_exists(target)) send(event.peer_id, "misc This player does not exist.", 0, true);
else
{
string uname = read_field(target, "username", target);
send(event.peer_id, "banstext "+uname+"\n"+format_ban(target), 0, true);
}
}
}
else if(parsed[0]=="getmutes" and index>-1 and parsed.length()>1)
{
/* Staff (moderator+) view a player's per-channel mute status, read-only, in the doc viewer. Same targeting as
/warnings: an online player by username or nickname, else a username for an offline account (mutes live on disk). */
if(rank_level(players[index].rank) < 1) { }
else
{
int ti = get_player_index_from(parsed[1]);
string target = (ti > -1) ? players[ti].name : parsed[1];
if(!account_exists(target)) send(event.peer_id, "misc This player does not exist.", 0, true);
else
{
string uname = read_field(target, "username", target);
send(event.peer_id, "mutestext "+uname+"\n"+format_mutes(target), 0, true);
}
}
}
else if(parsed[0]=="getreports" and index>-1)
{
/* Staff (moderator+) view every report on record, read-only, newest first, in the doc viewer. Unlike the
per-player viewers this takes no name. Non-staff is silently ignored. */
if(rank_level(players[index].rank) < 1) { }
else send(event.peer_id, "reportstext\n"+format_reports(), 0, true);
}
else if(parsed[0]=="getbansall" and index>-1)
{
/* Developer-only read-only overview of every banned account. Bans live on offline folders, so this is the only
way to see them all at once; like getreports it takes no name. Anyone below developer is silently ignored. */
if(rank_level(players[index].rank) < 3) { }
else send(event.peer_id, "bansalltext\n"+format_all_bans(), 0, true);
}
else if(parsed[0]=="menuresult" and index>-1 and parsed.length()>2)
{
on_menu_result(index, parsed[1], int(string_to_number(parsed[2])));
}
else if(parsed[0]=="roomaction" and index>-1 and parsed.length()>1)
{
/* A Ctrl+<key> room hotkey: run the named room-menu action directly, skipping the room menu. Only valid while
actually in a room (room_id != 0); do_room_action re-validates host-only actions (kick, delete, setpw) itself. */
if(players[index].room_id != 0) do_room_action(index, event.peer_id, parsed[1], true); // silent: a hotkey in the wrong context does nothing quietly (the menu path, on_menu_result, stays non-silent)
}
else if(parsed[0]=="gameaction" and index>-1 and parsed.length()>1)
{
/* A Ctrl+<key> round-menu hotkey: run the named round action directly, skipping the round menu. Only valid while
in a game; do_game_action's downstream commands (beginround, skipbuild) and pickers re-validate host/phase/staff. */
if(get_game_index(players[index].room_id) >= 0) do_game_action(index, event.peer_id, parsed[1]);
}
else if(parsed[0]=="openmenu" and index>-1)
{
/* The client asks the server to open the menu for wherever they are; the server is the authority on
the options. Lobby and rooms are server-driven now; the in-game menu is still client-rendered. */
if(!players[index].agreed)
{
/* Rules gate: the lobby menu is the only way into rooms/games, so blocking it (plus /accept, /reject, and
invites) keeps an unagreed player out of all gameplay until they agree. This is where the read/agree
reminder is shown, since there's no longer a login-time alert. */
send(event.peer_id, "misc You must read the server rules before you can play. Type /rules to read them, then /rules agree to continue, or /rules disagree to leave.", 0,true);
}
else if(players[index].room_id==0 or get_room_index(players[index].room_id)>-1)
{
push_actions_menu(index); // Enter in the lobby or a room opens the Actions menu (Account panel + the Lobby/Room panel)
}
else if(get_game_index(players[index].room_id)>-1)
{
push_game_menu(index); // Enter in a game = round controls
}
}
else if(parsed[0]=="openpanel" and index>-1 and parsed.length()>1)
{
/* A Ctrl+A / Ctrl+H hotkey jumps straight to an Actions-menu panel, skipping the Actions menu itself. Gated like
openmenu (no panels until you've agreed to the rules), and each panel is pushed only in its own context: the
account panel in the lobby or a room, the lobby panel only in the lobby, the room panel only in a room. A
wrong-context press does nothing quietly, matching the other context-specific hotkeys. */
if(players[index].agreed)
{
string which = parsed[1];
if(which == "account" and (players[index].room_id==0 or get_room_index(players[index].room_id)>-1)) push_account_menu(index);
else if(which == "lobby" and players[index].room_id==0) push_lobby_menu(index);
else if(which == "room" and get_room_index(players[index].room_id)>-1) push_room_menu(index);
}
}
else if(parsed[0]=="openpausemenu" and index>-1)
{
/* Escape in a game. The host, during a running round, pauses the whole game for everyone and gets the
pause menu; anyone else (or the host while idle/over) gets a plain leave menu that doesn't pause. */
int gi=get_game_index(players[index].room_id);
if(gi>-1)
{
bool ishost=(games[gi].host_peer==players[index].peer_id);
bool active=(games[gi].phase=="build" or games[gi].phase=="wave");
if(ishost and active) { pause_game(gi); push_pause_menu(index); }
else push_leave_menu(index);
}
}
else if(parsed[0]=="playagain" and index>-1 and parsed.length()>1)
{
/* Answer to the end-of-round "play again?" prompt. Only meaningful while the game is in the "over"
phase. No = leave to the office (migrates the host if needed); yes = stay. Once everyone who is left
has answered, the cavern resets to a fresh idle round for the host to begin. */
int gi=get_game_index(players[index].room_id);
if(gi>-1 and games[gi].phase=="over")
{
int gid=games[gi].id;
if(parsed[1]=="no") leave_game(players[index].peer_id);
else players[index].playagain_answered=true;
int gi2=get_game_index(gid); // leave_game may have removed the game if it emptied
if(gi2>-1 and games[gi2].phase=="over" and all_answered_playagain(gi2)) reset_for_new_round(gi2);
}
}
else if(parsed[0]=="createroom" and index>-1 and parsed.length()>1)
{
bool priv = (parsed[1]=="private");
string pass = (priv and parsed.length()>2) ? parsed[2] : "";
do_create_room(index, event.peer_id, priv, pass);
}
else if(parsed[0]=="leaveroom" and index>-1)
{
if(players[index].room_id != 0)
{
int lri=get_room_index(players[index].room_id);
string lhost = (lri>-1) ? rooms[lri].host : "";
string ltype = (lri>-1 and rooms[lri].is_private) ? "private" : "public";
remove_member(event.peer_id);
send(event.peer_id, "roomleft", 0,true);
set_room_scope(index, 0);
string lposs = pronoun_word(players[index].pronoun, "possessive", display_name_flagged(index));
string lwhere = (lhost=="") ? "a room" : (players[index].name==lhost ? lposs+" own "+ltype+" room" : display_name_flagged_for(lhost)+"'s "+ltype+" room");
broadcast_event(display_name_flagged(index)+" left "+lwhere+".", event.peer_id);
}
}
else if(parsed[0]=="startgame" and index>-1 and parsed.length()>2)
{
int ri=get_room_index(players[index].room_id);
if(ri==-1)
{
send(event.peer_id, "You must be in a room to start a game.", 0,true);
}
else
{
int size=int(string_to_number(parsed[1]));
if(size!=25 and size!=50 and size!=75 and size!=100) size=50;
bool solo=(parsed[2]=="solo");
string mode="pve"; // gameplay mode; defaults to the original pve for a missing or unrecognized arg
if(parsed.length()>3 and parsed[3]=="evp") mode="evp";
else if(parsed.length()>3 and parsed[3]=="pvp") mode="pvp";
double rcap = (parsed.length()>4) ? string_to_number(parsed[4]) : 0; // wall reinforce cap multiplier (2/4/8, or 0 = no limit); PVE/PVP only, EVP sends 0
if(rcap < 0) rcap = 0;
bool pileup = (parsed.length()>5 and parsed[5]=="1"); // PVE only: a fallen wall's bots pile onto the standing walls (Yes); EVP/PVP send 0
int gid=create_game(players[index].room_id, players[index].name, event.peer_id, size, solo, mode, rcap, pileup);
players[index].pregame_room = players[index].room_id; // the host started from their room; leaving the game returns them there
send(event.peer_id, "gamejoined "+gid+" "+size+" "+(solo?"solo":"open")+" "+mode+" "+players[index].name+"\n"+display_name_flagged(index), 0,true);
set_room_scope(index, gid);
send(event.peer_id, "gamephase idle 0 0", 0,true); // uniform 3-field gamephase (no active round, so wave 0)
// Only open games are joinable, so only those announce the "you can join" notice (mode-aware: "an EVP game" / "a PVE game").
if(!solo) broadcast_event(display_name_flagged(index)+" started "+(mode=="evp"?"an":"a")+" "+mode_tag(mode)+" game. You can join it from the room menu.", event.peer_id);
}
}
else if(parsed[0]=="leavegame" and index>-1)
{
broadcast_event(display_name_flagged(index)+" left the game.", event.peer_id);
leave_game(event.peer_id);
}
else if(parsed[0]=="beginround" and index>-1)
{
int gi=get_game_index(players[index].room_id);
if(gi==-1)
{
send(event.peer_id, "You are not in a game.", 0,true);
}
else if(games[gi].host_peer != event.peer_id)
{
send(event.peer_id, "Only the host can begin the round.", 0,true);
}
else if(games[gi].phase != "idle")
{
send(event.peer_id, "The round has already started.", 0,true);
}
else if(!games[gi].solo and games[gi].members.length() < 2)
{
send(event.peer_id, "You can't begin a round with yourself.", 0,true);
}
else if(games[gi].mode=="pvp")
{
/* PVP: enforce even, fully-assigned sides (1v1 or 2v2) before starting. On a passing gate, open the
build/prep phase like the other modes -- set_game_phase's PVP branch (pvp_build_setup) places each side
and arms the attackers; it deliberately avoids the shared PVE engine (no enemy bots, no blanket wood grant). */
string problem = pvp_start_problem(gi);
if(problem != "") send(event.peer_id, problem, 0,true);
else
{
games[gi].buildduration = build_seconds(games[gi].size);
set_game_phase(gi, "build");
}
}
else
{
games[gi].buildduration = build_seconds(games[gi].size);
set_game_phase(gi, "build");
}
}
else if(parsed[0]=="skipbuild" and index>-1)
{
int gi=get_game_index(players[index].room_id);
if(gi==-1)
{
send(event.peer_id, "You are not in a game.", 0,true);
}
else if(games[gi].host_peer != event.peer_id)
{
send(event.peer_id, "Only the host can skip the build phase.", 0,true);
}
else if(!is_staff(players[index].rank))
{
send(event.peer_id, "Only staff can skip the build phase.", 0,true);
}
else if(games[gi].phase != "build")
{
send(event.peer_id, "There is no build phase to skip.", 0,true);
}
else
{
set_game_phase(gi, "wave");
}
}
else if(parsed[0]=="stopgame" and index>-1 and parsed.length()>1)
{
/* Stop a specific game by id (the room menu's Stop-game list): allowed for staff (any game) or that
game's own host (e.g. a host who left a game running and wants to kill it from the room). */
int gi=get_game_index(int(string_to_number(parsed[1])));
if(gi==-1)
{
send(event.peer_id, "That game no longer exists.", 0,true);
}
else if(!is_staff(players[index].rank) and games[gi].host != players[index].name)
{
send(event.peer_id, "You don't have permission to stop that game.", 0,true);
}
else
{
send(event.peer_id, "misc You stopped the game.", 0,true);
broadcast_event(display_name_flagged_for(games[gi].host)+"'s game was stopped.", event.peer_id);
end_game(gi);
}
}
else if(parsed[0]=="stopgame" and index>-1)
{
int gi=get_game_index(players[index].room_id);
if(gi==-1)
{
send(event.peer_id, "You are not in a game.", 0,true);
}
else if(games[gi].host_peer != event.peer_id and !is_staff(players[index].rank))
{
send(event.peer_id, "Only the host or staff can stop the game.", 0,true);
}
else
{
send(event.peer_id, "misc You stopped the game.", 0,true);
broadcast_event(display_name_flagged_for(games[gi].host)+"'s game was stopped.", event.peer_id);
end_game(gi);
}
}
else if(parsed[0]=="joingame" and index>-1 and parsed.length()>1)
{
int ri=get_room_index(players[index].room_id);
if(ri==-1)
{
send(event.peer_id, "You must be in a room to join a game.", 0,true);
}
else
{
int gi=get_game_index(int(string_to_number(parsed[1])));
if(gi==-1)
{
send(event.peer_id, "That game no longer exists.", 0,true);
}
else if(games[gi].parent_room != players[index].room_id)
{
send(event.peer_id, "That game isn't in your room.", 0,true);
}
else if(games[gi].solo and games[gi].host_peer != event.peer_id)
{
// A Solo game is unjoinable by others, but its own host may rejoin it after stepping out.
send(event.peer_id, "That is a single-player game.", 0,true);
}
else if(games[gi].members.length() >= 4)
{
send(event.peer_id, "That game is full.", 0,true);
}
else if(games[gi].phase != "idle" and games[gi].phase != "build")
{
send(event.peer_id, "That game is already in progress.", 0,true);
}
else
{
join_game_now(index, gi);
}
}
}
else if(parsed[0]=="spectategame" and index>-1 and parsed.length()>1)
{
bool wo = (parsed.length() > 2 and parsed[2] == "out"); // optional deck arg for PVP: "out" = outdoor deck, anything else indoor
do_spectate(index, int(string_to_number(parsed[1])), wo); // start watching a game from the overhead deck
}
else if(parsed[0]=="leavewatch" and index>-1)
{
leave_watch(index); // stop watching, return to the room
}
else if(parsed[0]=="joinroom" and index>-1 and parsed.length()>1)
{
string pw = (parsed.length()>2) ? parsed[2] : "";
do_join_room(index, event.peer_id, int(string_to_number(parsed[1])), pw);
}
else if(parsed[0]=="rejoinlast" and index>-1 and parsed.length()>1)
{
/* Lobby quick-rejoin (client Ctrl+J / Ctrl+Shift+J): jump straight back into the last room of this kind you
joined this session. Public rejoins directly with no password; private reopens the password box prefilled with
the password you last used, so you just confirm it (do_join_room re-validates it against the room's current
password, so a changed password still fails). Tells you so if you haven't joined that kind of room yet. */
if(parsed[1]=="private")
{
if(players[index].last_private_room==0) send(event.peer_id, "You haven't joined a private room this session.", 0, true);
else ask_input(event.peer_id, "Enter the room's password.", "joinroom " + players[index].last_private_room, true, false, players[index].last_private_pw);
}
else
{
if(players[index].last_public_room==0) send(event.peer_id, "You haven't joined a public room this session.", 0, true);
else do_join_room(index, event.peer_id, players[index].last_public_room, "");
}
}
else if(parsed[0]=="scopemembers" and index>-1)
{
/* Everyone in a given space (room_id). With no argument it's the requester's own scope; with one it's
that specific space (the R/L/G keys use this — L passes 0 for the lobby). Works for lobby, office, or game. */
int target = (parsed.length()>1) ? int(string_to_number(parsed[1])) : players[index].room_id;
string payload="scopememberlist";
for(uint i=0; i<players.length(); i++)
if(players[i].room_id == target and !players[i].spectating and !players[i].held) payload+="\n"+afk_prefix(i)+display_name_flagged(i); // spectators aren't listed as participants; held (offline) sessions aren't either
send(event.peer_id, payload, 0,true);
}
else if(parsed[0]=="roomgamemembers" and index>-1)
{
// Game count + everyone across all games running in the requester's current room (the G key, from a room).
int rid = players[index].room_id;
int gamecount=0;
for(uint g=0; g<games.length(); g++) if(games[g].parent_room==rid) gamecount++;
string payload="roomgamelist "+gamecount;
for(uint i=0; i<players.length(); i++)
{
int gi=get_game_index(players[i].room_id);
if(gi>-1 and games[gi].parent_room == rid and !players[i].spectating and !players[i].held) payload+="\n"+afk_prefix(i)+display_name_flagged(i); // spectators aren't counted as game players; held (offline) sessions aren't either
}
send(event.peer_id, payload, 0,true);
}
else if(parsed[0]=="allgamemembers" and index>-1)
{
/* Game count + everyone in any game across the whole server (the G key, pressed from the lobby). Shares
the roomgamelist reply format with roomgamemembers; the client just labels it "on the server". */
string payload="roomgamelist "+games.length();
for(uint i=0; i<players.length(); i++)
if(get_game_index(players[i].room_id)>-1 and !players[i].spectating and !players[i].held) payload+="\n"+afk_prefix(i)+display_name_flagged(i); // spectators aren't counted as game players; held (offline) sessions aren't either
send(event.peer_id, payload, 0,true);
}
else if(parsed[0]=="roomsoverview" and index>-1)
{
/* Room count + everyone standing in a room's office (NOT its games) across the server (the R key, from
the lobby). Office occupants have room_id == that room's id; game players have room_id == a game id. */
string payload="roomsoverviewlist "+rooms.length();
for(uint i=0; i<players.length(); i++)
if(get_room_index(players[i].room_id)>-1 and !players[i].held) payload+="\n"+afk_prefix(i)+display_name_flagged(i); // held (offline) sessions aren't listed as office occupants
send(event.peer_id, payload, 0,true);
}
else if(parsed[0]=="kickfromroom" and index>-1 and parsed.length()>1)
{
int ri=get_room_index(players[index].room_id);
if(ri==-1)
{
send(event.peer_id, "You are not in a room.", 0,true);
}
else if(rooms[ri].host_peer != event.peer_id)
{
send(event.peer_id, "Only the host can kick players from the room.", 0,true);
}
else
{
int targetpeer=-1;
for(uint j=0; j<rooms[ri].members.length(); j++)
{
int pi=get_player_index(rooms[ri].members[j]);
if(pi>-1 and string_to_lower_case(players[pi].name)==string_to_lower_case(parsed[1])) { targetpeer=rooms[ri].members[j]; break; }
}
if(targetpeer==-1)
{
send(event.peer_id, "misc This player is not in your room.", 0,true);
}
else if(targetpeer==event.peer_id)
{
// Kicking yourself = leaving your own room. Mirror the leaveroom path: drop out to the lobby and tell everyone.
string lhost = rooms[ri].host;
string ltype = rooms[ri].is_private ? "private" : "public";
remove_member(event.peer_id);
send(event.peer_id, "roomleft", 0,true);
set_room_scope(index, 0);
string lposs = pronoun_word(players[index].pronoun, "possessive", display_name_flagged(index));
string lwhere = (players[index].name==lhost) ? lposs+" own "+ltype+" room" : display_name_flagged_for(lhost)+"'s "+ltype+" room";
broadcast_event(display_name_flagged(index)+" left "+lwhere+".", event.peer_id);
}
else if(get_player_index(targetpeer)>-1 and players[get_player_index(targetpeer)].room_id != rooms[ri].id)
{
send(event.peer_id, "That player is in a game and can't be kicked right now.", 0,true);
}
else
{
string hostname=rooms[ri].host;
string kind=rooms[ri].is_private?"private":"public";
int tpi=get_player_index(targetpeer);
string tdisp=(tpi>-1)?display_name_flagged(tpi):parsed[1]; // flag-aware kicked name, captured before removal
remove_member(targetpeer);
send(targetpeer, "roomkicked "+hostname+" "+kind+"\n"+display_name_flagged_for(hostname), 0,true); // 2nd line: rank-aware host name (may contain a space)
if(tpi>-1) set_room_scope(tpi, 0);
send(event.peer_id, "misc You kicked "+tdisp+".", 0,true); // kicker: first-person
broadcast_event(tdisp+" was kicked from "+display_name_flagged_for(hostname)+"'s "+kind+" room.", event.peer_id, targetpeer); // everyone else
}
}
}
else if(parsed[0]=="kickfromgame" and index>-1 and parsed.length()>1)
{
int gi=get_game_index(players[index].room_id);
if(gi==-1)
{
send(event.peer_id, "You are not in a game.", 0,true);
}
else if(games[gi].host_peer != event.peer_id)
{
send(event.peer_id, "Only the host can kick players from the game.", 0,true);
}
else
{
int targetpeer=-1, targetmi=-1;
for(uint j=0; j<games[gi].members.length(); j++)
{
int pi=get_player_index(games[gi].members[j]);
if(pi>-1 and string_to_lower_case(players[pi].name)==string_to_lower_case(parsed[1])) { targetpeer=games[gi].members[j]; targetmi=int(j); break; }
}
if(targetpeer==-1)
{
send(event.peer_id, "misc This player is not in your game.", 0,true);
}
else if(targetpeer==event.peer_id)
{
// Kicking yourself = leaving your own game. Mirror the leavegame path (host migration / game-end handled by leave_game).
broadcast_event(display_name_flagged(index)+" left the game.", event.peer_id);
leave_game(event.peer_id);
}
else
{
string hostname=games[gi].host;
string hostdisp=display_name_flagged_for(hostname);
int tpi=get_player_index(targetpeer);
string tdisp=(tpi>-1)?display_name_flagged(tpi):parsed[1]; // flag-aware kicked name, captured before removal
games[gi].members.remove_at(targetmi);
send(targetpeer, "gamekicked "+hostname+"\n"+hostdisp, 0,true); // 2nd line: rank-aware host name (may contain a space)
if(tpi>-1) set_room_scope(tpi, players[tpi].pregame_room); // back to where they came from: the room, or the lobby if invited from there
send(event.peer_id, "misc You kicked "+tdisp+".", 0,true); // kicker: first-person
send_to_game(games[gi].id, "misc "+tdisp+" was kicked from the game."); // remaining members and any watchers
if(games[gi].phase=="over" and all_answered_playagain(gi)) reset_for_new_round(gi); // the holdout may have just left
}
}
}
else if(parsed[0]=="deleteroom" and index>-1)
{
int ri=get_room_index(players[index].room_id);
if(ri==-1)
{
send(event.peer_id, "You are not in a room.", 0,true);
}
else
{
bool staff=is_staff(players[index].rank);
bool host=(rooms[ri].host_peer==event.peer_id);
bool alone=(rooms[ri].members.length()<=1);
if(!staff and !host)
{
send(event.peer_id, "Only the host can delete the room.", 0,true);
}
else if(!staff and !alone)
{
send(event.peer_id, "You can't delete the room while other players are in it.", 0,true);
}
else
{
// End any games running in this room first so their players aren't orphaned by the delete.
for(int g=int(games.length())-1; g>=0; g--)
if(games[g].parent_room==rooms[ri].id) end_game(g);
string disp=rooms[ri].host;
string kind=rooms[ri].is_private?"private":"public";
string hostdisp=display_name_flagged_for(rooms[ri].host);
// Bystanders (anyone not in this room) get a player-events note; the room's own members get roomdeleted below.
for(uint pe=0; pe<players.length(); pe++)
{
bool member=false;
for(uint mj=0; mj<rooms[ri].members.length(); mj++) if(rooms[ri].members[mj]==int(players[pe].peer_id)) { member=true; break; }
if(!member) send(players[pe].peer_id, "event "+hostdisp+"'s "+kind+" room was deleted.", 0,true);
}
for(uint j=0; j<rooms[ri].members.length(); j++)
{
int pi=get_player_index(rooms[ri].members[j]);
send(rooms[ri].members[j], "roomdeleted "+disp+" "+kind+"\n"+hostdisp, 0,true); // 2nd line: rank-aware host name (may contain a space)
if(pi>-1) set_room_scope(pi, 0);
}
// end_game above ejected any game spectators into this now-deleted office; sweep them on to the lobby too.
for(uint s=0; s<players.length(); s++)
if(players[s].room_id==rooms[ri].id and int(players[s].peer_id)!=event.peer_id) { send(players[s].peer_id, "roomleft", 0, true); set_room_scope(int(s), 0); }
if(rooms[ri].is_private) set_saved_private(rooms[ri].host, "");
else set_saved_public(rooms[ri].host, false);
clear_walls(rooms[ri].id); // the office is gone, so drop its walls.
rooms.remove_at(ri);
int hpi=get_online_index(disp);
if(hpi>-1) send_yourrooms(players[hpi].peer_id, disp);
}
}
}
else if(parsed[0]=="getroompassword" and index>-1)
{
int ri=get_room_index(players[index].room_id);
if(ri==-1)
{
send(event.peer_id, "You are not in a room.", 0,true);
}
else if(rooms[ri].host_peer != event.peer_id)
{
send(event.peer_id, "Only the host can view the room's password.", 0,true);
}
else if(!rooms[ri].is_private)
{
send(event.peer_id, "Only private rooms have a password.", 0,true);
}
else
{
send(event.peer_id, "roompassword "+rooms[ri].password, 0,true);
}
}
else if(parsed[0]=="setroompassword" and index>-1 and parsed.length()>1)
{
int ri=get_room_index(players[index].room_id);
if(ri==-1)
{
send(event.peer_id, "You are not in a room.", 0,true);
}
else if(rooms[ri].host_peer != event.peer_id)
{
send(event.peer_id, "Only the host can change the room's password.", 0,true);
}
else if(!rooms[ri].is_private)
{
send(event.peer_id, "Only private rooms have a password.", 0,true);
}
else if(parsed[1].length()<6 or parsed[1].length()>24)
{
send(event.peer_id, "Room passwords must be between 6 and 24 characters.", 0,true);
}
else
{
rooms[ri].password = parsed[1];
set_saved_private(rooms[ri].host, parsed[1]);
send(event.peer_id, "Your room's password has been changed successfully.", 0,true);
}
}
else if(parsed[0]=="restart" and index>-1 and rank_level(players[index].rank)>=3 and parsed.length()>1)
{
int secs=string_to_number(parsed[1]);
if(secs<1) secs=1;
send(0, "restartnotice "+format_restart_time(secs), 0,true);
restart_pending=true;
restart_delay=secs*1000;
restart_timer.restart();
}
else if(parsed[0]=="fastrestart" and index>-1 and rank_level(players[index].rank)>=3)
{
do_restart();
}
else if(parsed[0]=="freeze" and index>-1 and rank_level(players[index].rank)>=3)
{
if(world_frozen) send(event.peer_id, "misc The game is already frozen.", 0, true);
else
{
freeze_world();
/* Announce it to everyone the way the staff-flag flip is announced: AFK-, rank-, and nickname-aware, with the
gamestop cue riding in the alerts buffer (the client's worldfreeze handler plays it). Nobody chats or moves
until it's lifted. */
string wfann = "worldfreeze\nAttention! "+afk_prefix(index)+display_name_flagged(index)+" has frozen the game!";
for(uint wfi=0; wfi<players.length(); wfi++) send(players[wfi].peer_id, wfann, 0, true);
}
}
else if(parsed[0]=="unfreeze" and index>-1 and rank_level(players[index].rank)>=3)
{
if(!world_frozen) send(event.peer_id, "misc The game is not frozen.", 0, true);
else
{
unfreeze_world();
string wfann = "worldunfreeze\nAttention! "+afk_prefix(index)+display_name_flagged(index)+" has unfrozen the game!";
for(uint wfi=0; wfi<players.length(); wfi++) send(players[wfi].peer_id, wfann, 0, true);
}
}
else if(parsed[0]=="frozennotice")
{
/* The client asks for this when a developer types anything but a start/stop command in the frozen chat box; the
server owns the "you can't do that now" reply so it's authoritative and matches the notice a player gets on join. */
if(world_frozen) send(event.peer_id, "misc The game is currently frozen.", 0, true);
}
}
if(event.type == event_receive && event.channel == 3 && !world_frozen) // world-stop: drop all voice while frozen (only a developer's channel-0 freeze/unfreeze is honored)
{
int index=get_player_index(event.peer_id);
if(index>-1)
{
if(is_muted_now(index, "voice"))
{
/* Voice-muted: silently drop the stream. The client already knows its voice-mute state (voicemutestate at
spawn/restore plus the live muted/unmuted notices) and warns the player on O before opening the mic, so
a muted client shouldn't even reach here; this is just the authoritative backstop, no reply needed. */
}
else
{
string audio=get_event_message();
if(audio.length()>maxvoicebytes)
{
send(event.peer_id, "Your voice message was too large to send.", 0,true);
}
else
{
bool vrel=(audio.length()>0 and audio.substr(0,1)=="m"); // "m" = voice message: relay reliably so it arrives intact; "l" = live frame: unreliable
string relay=players[index].name+" "+players[index].x+" "+players[index].y+"\n"+audio;
for(uint i=0; i<players.length(); i++)
{
if(players[i].peer_id==event.peer_id or players[i].room_id!=players[index].room_id) continue;
if(player_ignores(int(i), players[index].name)) continue; // listener has the speaker on their personal ignore list
send(players[i].peer_id, relay, 3, vrel); // live frame unreliable (real-time stream; reliable retransmits at this packet rate inflate enet RTT and trip the peer timeout over a VPN); a voice message goes reliable so it arrives whole
}
}
}
}
}
if(event.type == event_receive && event.channel == 1 && !world_frozen) // world-stop: drop all chat while frozen (freeze/unfreeze ride channel 0)
{
    string message = get_event_message();
    bool messend = true;
    int index = get_player_index(event.peer_id);    
    if(index > -1)
{
        if(message.length() > 0)
{
            if(players[index].messagetimer.elapsed < 50) messend = false;            
            if(filter_crash(message) or (string_to_lower_case(players[index].language) != "unfiltered" and filter_chat(message)))
{
                send(event.peer_id, "misc Your message contains forbidden words, and therefore will not be sent.", 0, true); // misc buffer: spoken and logged
                messend = false;
                return;
            }
            if(message[0] == "/")
{
                messend = false;
                string[] parsed = string_split(message, " ", true);
                if(parsed[0] == "/motd" && rank_level(players[index].rank)>=1)
{
    if(parsed.length() > 1)
    {
        motd = string_replace(get_event_message(), "/motd ", "", true);
        file f;
        f.open("data/preffs/motd.svr", "w");
        f.write(motd);
        f.close();
        send(event.peer_id, "misc Message of the Day has been changed to: " + motd, 0, true); // actor: first-person confirmation in misc
        send(0, "play newmotd.ogg", 0, true); // everyone hears the dedicated new-MOTD cue
        string motdnotice = afk_prefix(index) + display_name_flagged(index) + " has changed the Message of the Day to: " + motd; // AFK + flag/nickname-aware (commands can be issued while AFK)
        send(0, "alertsilent "+motdnotice, 0, true); // the third-person notice into everyone's alerts buffer, the changer included, with no extra cue (newmotd already played for all)
    }
    else
    {
        send(event.peer_id, "Usage: /motd message", 0, true);
    }
}
                 else if(parsed[0] == "/pm" && parsed.length() >= 3)
{
                    string target_user = parsed[1];
                    string pm_message = string_join(parsed, " ", 2, parsed.length());
                    int target_index = get_player_index_from(target_user);
                    string target_name = (target_index > -1) ? players[target_index].name : target_user; // resolve to an account name (online by username or nickname, else whatever was typed) for the self-check
                    if(string_to_lower_case(target_name) == string_to_lower_case(players[index].name))
{
                        send(event.peer_id, "misc You can't send a private message to yourself.", 0, true); // like /report and /demote, you can't target yourself
                    }
                    else if(target_index > -1)
{
/* If the recipient has personally muted the sender, the PM can't be delivered -- tell the sender so (a reminder,
like other games), instead of the old silent fake "PM to" copy. player_ignores returns false when the sender is
staff, so staff PMs always go through. */
if(player_ignores(target_index, players[index].name)) send(event.peer_id, "misc This player has muted you.", 0, true);
else
{
send(event.peer_id, "PM to " + afk_prefix(target_index) + display_name_flagged(target_index) + ": " + pm_message, 2, true);
send(players[target_index].peer_id, "PM from " + afk_prefix(index) + display_name_flagged(index) + ": " + pm_message, 2, true);
}
                    }
else if(account_exists(target_user))
{
/* The recipient is offline but the account exists: queue the message for their next login instead of erroring.
Honor their personal ignore list the same as a live PM (staff exempt via account_ignores), and echo an
"Offline PM to" copy to the sender so they know it was saved rather than delivered. */
if(account_ignores(target_user, players[index].name)) send(event.peer_id, "misc This player has muted you.", 0, true);
else
{
string rdisp = read_field(target_user, "nickname", target_user); // the recipient's display name for the sender's echo
add_offline_pm(target_user, players[index].name, pm_message);
send(event.peer_id, "Offline PM to " + rdisp + ": " + pm_message, 2, true);
}
                    }
else
{
                        reply_target_not_found(event.peer_id, target_user);
                    }
                }
                else if(parsed[0] == "/me" && parsed.length() >= 2)
                {
                    if(is_muted_now(index, "global"))
                    {
                        send(event.peer_id, muted_chat_message(index, "global"), 0, true);
                    }
                    else if(spam_check_global(index))
                    {
                        // Anti-spam tripped: the player was just auto-muted in global and told why; drop this action.
                    }
                    else
                    {
                        string action = string_join(parsed, " ", 1, parsed.length());
                        relay_global(index, afk_prefix(index) + display_name_flagged(index) + " " + action); // global /me: same-language only
                    }
                }
                else if(parsed[0] == "/flag" && rank_level(players[index].rank) >= 1)
                {
                    players[index].flagged = !players[index].flagged;
                    set_flag(players[index].name, players[index].flagged);
                    string fverb = players[index].flagged ? "raised" : "lowered";
                    // Announce the flip to everyone with the rank shown (always, regardless of the flag state).
                    string fposs = pronoun_word(players[index].pronoun, "possessive", players[index].rank+" "+players[index].nickname);
string fann = "flagswitch "+(players[index].flagged?"1":"0")+"\nAttention! "+players[index].rank+" "+players[index].nickname+" has "+fverb+" "+fposs+" staff flag.";
                    for(uint ffi=0; ffi<players.length(); ffi++) send(players[ffi].peer_id, fann, 0, true);
                    broadcast_pos(index); // refresh the visible rank in everyone's player tracker
                }
                else if(parsed[0] == "/changemail" && parsed.length() >= 2)
                {
                    /* Change an account's cosmetic email (email.usr). Self: /changemail <email> (anyone). Admin:
                    /changemail <username> <email> (administrator+, at-or-below rank, online target). No logout -- email is cosmetic. */
                    if(parsed.length() == 2)
                    {
                        string em = parsed[1];
                        if(string_contains(em, "@", 1) < 0) send(event.peer_id, "That is not a valid email address.", 0, true);
                        else { write_field(players[index].name, "email", em); send(event.peer_id, "misc Your email has been changed to "+em+".", 0, true); }
                    }
                    else if(rank_level(players[index].rank) >= 2)
                    {
                        int ti = get_player_index_from(parsed[1]);
                        if(ti < 0) reply_target_not_found(event.peer_id, parsed[1]);
                        else if(rank_level(players[ti].rank) > rank_level(players[index].rank)) send(event.peer_id, "You can't change the email of someone above your rank.", 0, true);
                        else
                        {
                            string em = parsed[2];
                            if(string_contains(em, "@", 1) < 0) send(event.peer_id, "That is not a valid email address.", 0, true);
                            else
                            {
                                write_field(players[ti].name, "email", em);
                                send(event.peer_id, "misc You changed "+display_name_flagged(ti)+"'s email.", 0, true);
                                send(players[ti].peer_id, "misc Your email has been changed by staff.", 0, true);
                                notify_staff_audit(afk_prefix(index)+display_name_flagged(index)+" changed "+afk_prefix(ti)+display_name_flagged(ti)+"'s email.", -1);
                            }
                        }
                    }
                    else send(event.peer_id, "Usage: /changemail email.", 0, true);
                }
                else if(parsed[0] == "/changename" && parsed.length() == 3)
                {
                    /* Administrator+ renames an account (the username, the identity), resetting its nickname to the new
                    name. Online-only target (username or nickname), at-or-below rank. Quiet: only the renamed player,
                    a staff audit line, and the actor are told. The rename carries the whole account folder and fixes
                    up owner status and everyone's personal ignore lists; the player is then logged out to sign back in. */
                    if(rank_level(players[index].rank) < 2) send(event.peer_id, "misc You can't rename players.", 0, true);
                    else
                    {
                        int ti = get_player_index_from(parsed[1]);
                        string newname = parsed[2];
                        if(ti < 0) reply_target_not_found(event.peer_id, parsed[1]);
                        else if(rank_level(players[ti].rank) > rank_level(players[index].rank)) send(event.peer_id, "misc You can't rename someone above your rank.", 0, true);
                        else if(newname.length() < 6 or newname.length() > 24) send(event.peer_id, "misc The new name must be between 6 and 24 characters.", 0, true);
                        else if(filterchar(newname, true)) send(event.peer_id, "misc The new name may only contain letters, numbers, hyphens and underscores.", 0, true);
                        else if(account_exists(newname)) send(event.peer_id, "misc An account with that name already exists.", 0, true);
                        else
                        {
                            string oldname = players[ti].name;
                            string oldnick = players[ti].nickname;
                            string oldrank = players[ti].rank;
                            int tpeer = players[ti].peer_id;
                            if(!rename_account(oldname, newname)) send(event.peer_id, "misc The rename failed, so the account was not changed.", 0, true);
                            else
                            {
                                // Keep online players' in-memory ignore lists pointed at the renamed player this session too.
                                for(uint pi=0; pi<players.length(); pi++)
                                    for(uint k=0; k<players[pi].ignored.length(); k++)
                                        if(string_to_lower_case(players[pi].ignored[k]) == string_to_lower_case(oldname)) players[pi].ignored[k] = newname;
                                send(event.peer_id, "misc You renamed "+display_name_flagged(ti)+" to "+newname+".", 0, true);
                                notify_staff_audit(afk_prefix(index)+display_name_flagged(index)+" renamed "+afk_prefix(ti)+display_name_flagged(ti)+" to "+newname+".", -1);
                                /* Log the renamed player out: announce them offline under the OLD name, tell their client to
                                return to the connection menu, then drop them from the roster. The ensuing disconnect handles
                                host migration and room/game cleanup if they were hosting. */
                                send(0, "offline "+oldname+" "+oldrank+" "+oldnick, 0, true);
                                send(tpeer, "renamed "+newname, 0, true);
                                players.remove_at(ti);
                            }
                        }
                    }
                }
                else if((parsed[0] == "/nickname" or parsed[0] == "/nick") && parsed.length() >= 2)
                {
                    if(parsed.length() == 2)
                    {
                        apply_nickname(index, parsed[1], event.peer_id, true); // set your own (or "default")
                    }
                    else if(rank_level(players[index].rank) >= 1)
                    {
                        // Staff form: /nick <username> <altname> (all staff, targets an online player by username).
                        int ti = get_player_index_from(parsed[1]);
                        if(ti < 0)
                        {
                            reply_target_not_found(event.peer_id, parsed[1]);
                        }
                        else apply_nickname(ti, parsed[2], event.peer_id, false);
                    }
                    else send(event.peer_id, "Usage: /nick name, or /nick default.", 0, true);
                }
                else if(parsed[0] == "/kick" && rank_level(players[index].rank) >= 1)
                {
                    if(parsed.length() >= 2)
                    {
                        int kick_index = get_player_index_from(parsed[1]);
                        if(kick_index > -1)
                        {
                            if(rank_level(players[kick_index].rank) > rank_level(players[index].rank))
                            {
                                send(event.peer_id, "misc You can't kick someone above your rank.", 0, true); // at-or-below-rank protection, like /ban and /mute (you can still kick yourself and peers)
                            }
                            else
                            {
                            string kname = players[kick_index].name;
                            string krank = players[kick_index].rank;
                            string knick = players[kick_index].nickname;
                            int kpeer = players[kick_index].peer_id;
                            string kdisp = afk_prefix(kick_index)+display_name_flagged(kick_index); // capture before removal for the staff note
                            string adisp = afk_prefix(index)+display_name_flagged(index);           // actor's name; capture before removal, since remove_at can shift index
                            string reason = "";
                            for(uint r=2; r<parsed.length(); r++) reason += (reason == "" ? "" : " ") + parsed[r];
                            // Staff reason: crash strings only (staff may quote what the player did); a caught reason is dropped and the kick still happens.
                            bool reason_dropped = (reason != "" and filter_crash(reason));
                            if(reason_dropped) reason = "";
                            players.remove_at(kick_index);
                            send(kpeer, "kicked"+(reason == "" ? "" : " "+reason), 0, true);
                            for(uint i=0; i<players.length(); i++)
                            {
                                send(players[i].peer_id, "kickannounce "+kname+" "+krank+" "+knick, 0, true);
                            }
                            notify_staff_audit(adisp+" kicked "+kdisp+(reason == "" ? "." : ": "+reason), event.peer_id); // other staff see the reason (the public announcement doesn't carry it)
                            if(reason_dropped) send(event.peer_id, "misc That reason contained a screen reader crash string, so the kick went through without it.", 0, true);
                            }
                        }
                        else
                        {
                            reply_target_not_found(event.peer_id, parsed[1]);
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /kick username, or /kick username reason", 0, true);
                    }
                }
                else if(parsed[0] == "/kickall" && rank_level(players[index].rank) >= 3)
                {
                    /* Developer world-clear: disconnect every player who isn't a developer, so you and any co-developer
                    stay. An optional reason after the command is shown to each kicked player, crash-filtered like
                    /kick (a caught reason is dropped and the kicks still happen). Everyone is gathered first, then
                    torn down together, so the roster shifting mid-loop can't skip anyone. */
                    string adisp = afk_prefix(index)+display_name_flagged(index); // actor's name; capture before removal, since remove_at shifts index
                    string reason = "";
                    for(uint r=1; r<parsed.length(); r++) reason += (reason == "" ? "" : " ") + parsed[r];
                    bool reason_dropped = (reason != "" and filter_crash(reason));
                    if(reason_dropped) reason = "";
                    int[] targets;
                    for(uint i=0; i<players.length(); i++)
                        if(rank_level(players[i].rank) < 3) targets.insert_last(players[i].peer_id); // everyone below developer, live or held
                    int kicked_count = 0;
                    for(uint t=0; t<targets.length(); t++)
                    {
                        if(get_player_index(targets[t]) < 0) continue; // already gone (a teardown above closed their game/room and removed them)
                        if(targets[t] >= 0) send(targets[t], "kicked"+(reason == "" ? "" : " "+reason), 0, true); // live player: tell their client to leave (held sessions have a negative sentinel peer, no one to notify)
                        handle_disconnect_games(targets[t]);
                        handle_disconnect_rooms(targets[t]);
                        int pj = get_player_index(targets[t]); // re-find: the teardown can shift indices
                        if(pj > -1) players.remove_at(pj);
                        kicked_count++;
                    }
                    if(kicked_count == 0) send(event.peer_id, "misc There is no one to kick.", 0, true);
                    else
                    {
                        send(event.peer_id, "misc You kicked "+kicked_count+(kicked_count == 1 ? " player" : " players")+" from the server.", 0, true);
                        notify_staff_audit(adisp+" kicked everyone from the server"+(reason == "" ? "." : ": "+reason), event.peer_id); // any remaining developers see who cleared it (and why)
                        if(reason_dropped) send(event.peer_id, "misc That reason contained a screen reader crash string, so the players were kicked without it.", 0, true);
                    }
                }
                else if(parsed[0] == "/promote" && rank_level(players[index].rank) >= 1)
                {
                    if(parsed.length() >= 3)
                    {
                        string tname = parsed[1];
                        string newrank = string_to_lower_case(parsed[2]);
                        int ti = get_player_index_from(tname); // online-only, by username or nickname
                        if(newrank != "moderator" && newrank != "administrator" && newrank != "developer")
                        {
                            send(event.peer_id, "Invalid rank. Choose moderator, administrator, or developer.", 0, true);
                        }
                        else if(rank_level(newrank) > rank_level(players[index].rank))
                        {
                            send(event.peer_id, "You can't promote someone above your own rank.", 0, true);
                        }
                        else if(ti < 0)
                        {
                            reply_target_not_found(event.peer_id, tname);
                        }
                        else if(rank_level(players[ti].rank) > rank_level(players[index].rank))
                        {
                            send(event.peer_id, "You can't change the rank of someone above your own rank.", 0, true);
                        }
                        else if(rank_level(newrank) <= rank_level(players[ti].rank))
                        {
                            send(event.peer_id, "alert "+display_name_flagged(ti)+" is already that rank or higher. Use /demote to lower a rank.", 0, true);
                        }
                        else
                        {
                            string oldrank = players[ti].rank;
                            set_rank(players[ti].name, newrank);
                            players[ti].rank = newrank;
                            send(players[ti].peer_id, "rankchange promoted "+oldrank+" "+newrank, 0, true);
                            send(event.peer_id, "alert "+display_name_flagged(ti)+" has been promoted to "+newrank+".", 0, true);
                            notify_staff_audit(afk_prefix(index)+display_name_flagged(index)+" promoted "+afk_prefix(ti)+display_name_flagged(ti)+" to "+newrank+".", -1);
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /promote username rank.", 0, true);
                    }
                }
                else if(parsed[0] == "/demote" && rank_level(players[index].rank) >= 1)
                {
                    if(parsed.length() >= 3)
                    {
                        string tname = parsed[1];
                        string newrank = string_to_lower_case(parsed[2]);
                        int ti = get_player_index_from(tname); // online-only, by username or nickname
                        if(newrank != "player" && newrank != "moderator" && newrank != "administrator")
                        {
                            send(event.peer_id, "Invalid rank. Choose player, moderator, or administrator.", 0, true);
                        }
                        else if(ti < 0)
                        {
                            reply_target_not_found(event.peer_id, tname);
                        }
                        else if(is_owner(players[ti].name))
                        {
                            send(event.peer_id, "misc You can't demote yourself as a developer.", 0, true);
                        }
                        else if(rank_level(players[ti].rank) > rank_level(players[index].rank))
                        {
                            send(event.peer_id, "You can't demote someone above your own rank.", 0, true);
                        }
                        else if(rank_level(newrank) >= rank_level(players[ti].rank))
                        {
                            send(event.peer_id, "alert "+display_name_flagged(ti)+" is already that rank or lower. Use /promote to raise a rank.", 0, true);
                        }
                        else
                        {
                            string oldrank = players[ti].rank;
                            set_rank(players[ti].name, newrank);
                            players[ti].rank = newrank;
                            send(players[ti].peer_id, "rankchange demoted "+oldrank+" "+newrank, 0, true);
                            send(event.peer_id, "alert "+display_name_flagged(ti)+" has been demoted to "+newrank+".", 0, true);
                            notify_staff_audit(afk_prefix(index)+display_name_flagged(index)+" demoted "+afk_prefix(ti)+display_name_flagged(ti)+" to "+newrank+".", -1);
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /demote username rank.", 0, true);
                    }
                }
                else if((parsed[0] == "/notifyplayer" || parsed[0] == "/notplayer") && is_staff(players[index].rank))
                {
                    if(parsed.length() >= 3)
                    {
                        int ti = get_player_index_from(parsed[1]);
                        if(ti > -1)
                        {
                            string nmsg = string_join(parsed, " ", 2, parsed.length());
                            send(players[ti].peer_id, "notify "+nmsg, 0, true);
                            send(event.peer_id, "misc Notification sent to "+players[ti].name+".", 0, true);
                            notify_staff_audit(afk_prefix(index)+display_name_flagged(index)+" sent a notification to "+afk_prefix(ti)+display_name_flagged(ti)+".", -1);
                        }
                        else
                        {
                            reply_target_not_found(event.peer_id, parsed[1]);
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /notifyplayer username message", 0, true);
                    }
                }
                else if(parsed[0] == "/warn" && rank_level(players[index].rank) >= 2)
                {
                    if(parsed.length() >= 4)
                    {
                        string wname = parsed[1];
                        int wlevel = int(string_to_number(parsed[2]));
                        string wreason = string_join(parsed, " ", 3, parsed.length());
                        int ti = get_player_index_from(wname); // online-only, by username or nickname
                        if(wlevel < 1 || wlevel > 4)
                        {
                            send(event.peer_id, "Warning level must be between 1 and 4.", 0, true);
                        }
                        else if(ti < 0)
                        {
                            reply_target_not_found(event.peer_id, wname);
                        }
                        else if(rank_level(players[ti].rank) > rank_level(players[index].rank))
                        {
                            send(event.peer_id, "You can't warn someone above your own rank.", 0, true);
                        }
                        else
                        {
                            /* The reason is shown to the warned player, so a crash string must never get through. Like
                            ban, a staff reason is crash-filtered only (not profanity), so staff can quote the offense;
                            a reason that trips the crash filter is dropped and the warning still lands. */
                            bool wreason_dropped = filter_crash(wreason);
                            if(wreason_dropped) wreason = "";
                            int wcount = add_warning(players[ti].name, wlevel, players[index].name, wreason);
                            send(players[ti].peer_id, "warn "+wlevel+"\n"+display_name(index)+"\n"+wreason, 0, true);
                            send(event.peer_id, "misc Warned "+display_name_flagged(ti)+" (level "+wlevel+"). This is warning number "+wcount+".", 0, true);
                            if(wreason_dropped) send(event.peer_id, "misc That reason contained a screen reader crash string, so the warning went through without it.", 0, true);
                            for(uint wsi=0; wsi<players.length(); wsi++)
                            {
                                if(is_staff(players[wsi].rank) && players[wsi].peer_id != event.peer_id)
                                    send(players[wsi].peer_id, "misc "+display_name(index)+" warned "+display_name_flagged(ti)+" (level "+wlevel+"): "+wreason, 0, true);
                            }
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /warn username level reason.", 0, true);
                    }
                }
                else if(parsed[0] == "/notify" && is_staff(players[index].rank))
                {
                    if(parsed.length() >= 2)
                    {
                        string nmsg = string_join(parsed, " ", 1, parsed.length());
                        send(0, "notify "+nmsg, 0, true);
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /notify message", 0, true);
                    }
                }
                else if(parsed[0] == "/mute" && rank_level(players[index].rank) >= 2)
                {
                    if(parsed.length() >= 3)
                    {
                        string channel = string_to_lower_case(parsed[2]);
                        int ti = resolve_mute_target(index, parsed[1], channel, "mute");
                        if(ti > -1)
                        {
                            array<string> chans = mute_channels_for(channel);
                            bool allmuted = true;
                            for(uint c=0; c<chans.length(); c++) if(get_player_mute(ti, chans[c]) == -1) allmuted = false;
                            if(allmuted)
                            {
                                send(event.peer_id, "misc "+display_name_flagged(ti)+" is already muted in "+(channel=="all"?"all channels":("the "+channel+" channel"))+".", 0, true);
                            }
                            else
                            {
                                int dur = (parsed.length() >= 4) ? int(string_to_number(parsed[3])) : 0;
                                if(dur < 0) dur = 0;
                                int64 until = (dur > 0) ? (now_epoch() + dur) : 0;
                                for(uint c=0; c<chans.length(); c++) { set_channel_mute(players[ti].name, chans[c], until); set_player_mute(ti, chans[c], until); }
                                notify_target_mute(ti, channel, true, dur);
                                announce_mute_to_others(display_name(ti), players[ti].peer_id, channel, true);
                            }
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /mute username channel [seconds].", 0, true);
                    }
                }
                else if(parsed[0] == "/unmute" && rank_level(players[index].rank) >= 2)
                {
                    if(parsed.length() >= 3)
                    {
                        string channel = string_to_lower_case(parsed[2]);
                        int ti = resolve_mute_target(index, parsed[1], channel, "unmute");
                        if(ti > -1)
                        {
                            array<string> chans = mute_channels_for(channel);
                            bool anymuted = false;
                            for(uint c=0; c<chans.length(); c++) if(get_player_mute(ti, chans[c]) != -1) anymuted = true;
                            if(!anymuted)
                            {
                                send(event.peer_id, "misc "+display_name_flagged(ti)+" is not muted in "+(channel=="all"?"any channel":("the "+channel+" channel"))+".", 0, true);
                            }
                            else
                            {
                                for(uint c=0; c<chans.length(); c++) { clear_channel_mute(players[ti].name, chans[c]); set_player_mute(ti, chans[c], -1); }
                                notify_target_mute(ti, channel, false, 0);
                                announce_mute_to_others(display_name(ti), players[ti].peer_id, channel, false);
                            }
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /unmute username channel.", 0, true);
                    }
                }
                else if(parsed[0] == "/muteall" && rank_level(players[index].rank) >= 3)
                {
                    /* Developer mass-mute: apply the same mute as /mute to every online player who isn't a developer
                    (mods and admins included; you and any co-developer are spared). It persists per account like a
                    normal mute -- a reconnecting player stays muted, timed mutes expire on their own. Each muted
                    player gets their own notice, but the per-player "was muted" broadcast is suppressed (dozens of
                    lines would flood everyone); you get one confirmation and any remaining developers a quiet note. */
                    if(parsed.length() >= 2)
                    {
                        string channel = string_to_lower_case(parsed[1]);
                        if(channel != "all" and !valid_mute_channel(channel))
                        {
                            send(event.peer_id, "misc That is not a channel you can mute; use global, local, voice, team, or all.", 0, true);
                        }
                        else
                        {
                            int dur = (parsed.length() >= 3) ? int(string_to_number(parsed[2])) : 0;
                            if(dur < 0) dur = 0;
                            int64 until = (dur > 0) ? (now_epoch() + dur) : 0;
                            array<string> chans = mute_channels_for(channel);
                            string adisp = afk_prefix(index)+display_name_flagged(index);
                            string chan_phrase = (channel=="all" ? "all channels" : "the "+channel+" channel");
                            int muted_count = 0;
                            for(uint i=0; i<players.length(); i++)
                            {
                                if(rank_level(players[i].rank) >= 3) continue; // developers (including you) are never mass-muted
                                for(uint c=0; c<chans.length(); c++) { set_channel_mute(players[i].name, chans[c], until); set_player_mute(int(i), chans[c], until); }
                                if(players[i].peer_id >= 0) notify_target_mute(int(i), channel, true, dur); // live players hear their own notice; held sessions are muted silently and learn on reconnect
                                muted_count++;
                            }
                            if(muted_count == 0) send(event.peer_id, "misc There is no one to mute.", 0, true);
                            else
                            {
                                send(event.peer_id, "misc You muted "+muted_count+(muted_count == 1 ? " player" : " players")+" in "+chan_phrase+".", 0, true);
                                notify_staff_audit(adisp+" muted everyone in "+chan_phrase+".", event.peer_id);
                            }
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /muteall channel, or /muteall channel seconds.", 0, true);
                    }
                }
                else if(parsed[0] == "/unmuteall" && rank_level(players[index].rank) >= 3)
                {
                    /* Lifts a mass mute: clears the mute in this channel for every online non-developer who has one.
                    Individual mutes in the channel are cleared too -- there's no way to tell them apart, and a
                    developer using this means to wipe the channel clean. */
                    if(parsed.length() >= 2)
                    {
                        string channel = string_to_lower_case(parsed[1]);
                        if(channel != "all" and !valid_mute_channel(channel))
                        {
                            send(event.peer_id, "misc That is not a channel you can unmute; use global, local, voice, team, or all.", 0, true);
                        }
                        else
                        {
                            array<string> chans = mute_channels_for(channel);
                            string adisp = afk_prefix(index)+display_name_flagged(index);
                            string chan_phrase = (channel=="all" ? "all channels" : "the "+channel+" channel");
                            int unmuted_count = 0;
                            for(uint i=0; i<players.length(); i++)
                            {
                                if(rank_level(players[i].rank) >= 3) continue;
                                bool anymuted = false;
                                for(uint c=0; c<chans.length(); c++) if(get_player_mute(int(i), chans[c]) != -1) anymuted = true;
                                if(!anymuted) continue;
                                for(uint c=0; c<chans.length(); c++) { clear_channel_mute(players[i].name, chans[c]); set_player_mute(int(i), chans[c], -1); }
                                if(players[i].peer_id >= 0) notify_target_mute(int(i), channel, false, 0);
                                unmuted_count++;
                            }
                            if(unmuted_count == 0) send(event.peer_id, "misc No one was muted in "+(channel=="all" ? "any channel" : chan_phrase)+".", 0, true);
                            else
                            {
                                send(event.peer_id, "misc You unmuted "+unmuted_count+(unmuted_count == 1 ? " player" : " players")+" in "+chan_phrase+".", 0, true);
                                notify_staff_audit(adisp+" unmuted everyone in "+chan_phrase+".", event.peer_id);
                            }
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /unmuteall channel.", 0, true);
                    }
                }
                else if(parsed[0] == "/ban" && rank_level(players[index].rank) >= 2)
                {
                    // Permanent ban. Everything after the username is an optional reason.
                    if(parsed.length() >= 2)
                    {
                        string tname = parsed[1];
                        int ti = get_player_index_from(tname); // online-only, by username or nickname
                        if(ti < 0)
                        {
                            reply_target_not_found(event.peer_id, tname);
                        }
                        else if(rank_level(players[ti].rank) > rank_level(players[index].rank))
                        {
                            send(event.peer_id, "You can't ban someone above your own rank.", 0, true);
                        }
                        else
                        {
                            string reason = "";
                            for(uint r=2; r<parsed.length(); r++) reason += (reason == "" ? "" : " ") + parsed[r];
                            perform_ban(event.peer_id, ti, 0, reason);
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /ban username, or /ban username reason", 0, true);
                    }
                }
                else if(parsed[0] == "/tempban" && rank_level(players[index].rank) >= 2)
                {
                    // Timed ban. The seconds are required and must be at least 1; everything after them is an optional reason.
                    if(parsed.length() >= 3)
                    {
                        string tname = parsed[1];
                        int dur = int(string_to_number(parsed[2]));
                        if(dur < 1)
                        {
                            send(event.peer_id, "Usage: /tempban username seconds, or /tempban username seconds reason", 0, true);
                        }
                        else
                        {
                            int ti = get_player_index_from(tname); // online-only, by username or nickname
                            if(ti < 0)
                            {
                                reply_target_not_found(event.peer_id, tname);
                            }
                            else if(rank_level(players[ti].rank) > rank_level(players[index].rank))
                            {
                                send(event.peer_id, "You can't ban someone above your own rank.", 0, true);
                            }
                            else
                            {
                                string reason = "";
                                for(uint r=3; r<parsed.length(); r++) reason += (reason == "" ? "" : " ") + parsed[r];
                                perform_ban(event.peer_id, ti, dur, reason);
                            }
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /tempban username seconds, or /tempban username seconds reason", 0, true);
                    }
                }
                else if(parsed[0] == "/unban" && rank_level(players[index].rank) >= 2)
                {
                    if(parsed.length() >= 2)
                    {
                        string tname = parsed[1];
                        if(!account_exists(tname)) // case-insensitive, like login/account_dir: /unban Bob resolves account bob
                        {
                            send(event.peer_id, "misc This player does not exist.", 0, true);
                        }
                        else if(get_ban_until(tname) == -1)
                        {
                            send(event.peer_id, tname+" is not banned.", 0, true);
                        }
                        else
                        {
                            clear_ban(tname);
                            send(event.peer_id, tname+" has been unbanned.", 0, true);
                            notify_staff_audit(afk_prefix(index)+display_name_flagged(index)+" unbanned "+tname+".", -1);
                        }
                    }
                    else
                    {
                        send(event.peer_id, "Usage: /unban username", 0, true);
                    }
                }
                else if(parsed[0] == "/report" && parsed.length() >= 3)
                {
                    /* Anyone can report a player to the staff. Target plus a required reason (everything after the
                    name). An offline player is accepted by username, since the point is often to report someone
                    who just left. The report is logged to reports.svr and pushed live to every online staffer. */
                    string tname = parsed[1];
                    int ti = get_player_index_from(tname); // online by username or nickname
                    string target = (ti > -1) ? players[ti].name : tname;
                    if(!account_exists(target))
                    {
                        send(event.peer_id, "misc This player does not exist.", 0, true);
                    }
                    else if(string_to_lower_case(target) == string_to_lower_case(players[index].name))
                    {
                        send(event.peer_id, "misc You can't report yourself.", 0, true);
                    }
                    else
                    {
                        string reason = "";
                        for(uint r=2; r<parsed.length(); r++) reason += (reason == "" ? "" : " ") + parsed[r];
                        if(filter_crash(reason) or filter_chat(reason))
                        {
                            /* A report is player-authored and shown to staff, so it gets both filters like local chat.
                            The reason IS the substance of a report, so a bad one is rejected outright rather than
                            filed blank; the player just retypes (there's no countdown to lose, unlike AFK). */
                            send(event.peer_id, "misc Your report was not sent because its reason contained forbidden words.", 0, true);
                        }
                        else
                        {
                            string location = report_location_phrase(index);
                            string reporteddisp = (ti > -1) ? display_name_flagged(ti) : target;
                            add_report(players[index].name, target, location, reason);
                            string alert = "Report from " + display_name_flagged(index) + " about " + reporteddisp + " in " + location + ": " + reason;
                            for(uint i=0; i<players.length(); i++)
                                if(is_staff(players[i].rank) && int(i) != index) send(players[i].peer_id, "report "+alert, 0, true);
                            send(event.peer_id, "misc Your report has been sent to the staff.", 0, true);
                        }
                    }
                }
            }
        }
        if(messend == true)
{
            if(is_muted_now(index, "global"))
            {
                send(event.peer_id, muted_chat_message(index, "global"), 0, true);
            }
            else if(spam_check_global(index))
            {
                // Anti-spam tripped: the player was just auto-muted in global and told why; drop this message.
            }
            else
            {
            players[index].messagetimer.restart();
            string what;
            what += afk_prefix(index) + display_name_flagged(index) + ": " + message;
            relay_global(index, what); // global chat: only same-language players hear it
            }
        }
    }
}
}
