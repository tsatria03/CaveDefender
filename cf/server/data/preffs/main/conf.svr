# CaveDefender server configuration. Each line is one setting -- its name, an equals sign, then the value.
# Lines starting with a hash are comments, ignored by the server. The server rewrites this file at startup and
# when a setting changes at runtime (like the owner list), so edit the values here with the server stopped;
# any hand-added comments will be replaced by these.
# All settings take effect on restart.

# Network: the UDP port to listen on, and the most players allowed online at once.
port=25562
userlimit=200

# Owner accounts: up to three comma-separated aliases for the single owner, each forced to developer rank and
# matched without case sensitivity; a blank value means no owner. Maintained automatically on owner rename or transfer.
owners=DevilGuardian,tsatria03,tony

# Rules agreement: raise rulesver to make everyone re-read and re-agree to the rules once. ruleswitch is the master
# gate -- 1 means players must agree before they can play, 0 turns the gate off so anyone can play unagreed.
rulesver=4
ruleswitch=1

# Global-chat anti-spam auto-mute: spamguard is the master switch (1 on, 0 off). A non-staff player who sends
# spamcount messages within spamtime milliseconds is auto-muted in global chat for spamdir seconds (0 is indefinite).
spamguard=1
spamcount=5
spamtime=3000
spamdir=600
