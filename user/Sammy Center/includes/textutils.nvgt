string text;
void butcherize()
{
text=input_box("text butcherizer","Enter the text you would like butchered.");
text=string_to_lower_case(text);
text=string_replace(text, "a", "ae", true);
text=string_replace(text, "e", "ea", true);
text=string_replace(text, "i", "ie", true);
text=string_replace(text, "o", "oa", true);
text=string_replace(text, "u", "uh", true);
text=string_replace(text, "c", "k", true);
text=string_replace(text, "g", "j", true);
text=string_replace(text, "m", "n", true);
text=string_replace(text, "s", "r", true);
text=string_replace(text, "v", "w", true);
text=string_replace(text, "n", "m", true);
text=string_replace(text, "r", "t", true);
text=string_replace(text, "b", "h", true);
text=string_replace(text, "t", "p", true);
text=string_replace(text, "p", "d", true);
text=string_replace(text, "1", "4", true);
text=string_replace(text, "2", "6", true);
text=string_replace(text, "3", "8", true);
text=string_replace(text, "6", "9", true);
text=string_replace(text, "7", "12", true);
text=string_replace(text, "5", "10", true);
cd("success",text, false);
}
void capitalize()
{
text=input_box("text changer","Enter the text you would like capitalized.");
text=string_to_upper_case(text);
cd("success",text, false);
}
void change()
{
text=input_box("text changer","Enter the text you would like changed.");
text=string_to_lower_case(text);
text=string_replace(text, "a", "ae", true);
text=string_replace(text, "is", "is not", true);
text=string_replace(text, "i ", "you ", true);
text=string_replace(text, " am", " are", true);
text=string_replace(text, "audio", "video", true);
text=string_replace(text, "game", "movie", true);
text=string_replace(text, "jaws", "nvda", true);
text=string_replace(text, "window-eyes", "supernova", true);
text=string_replace(text, "english", "spanish", true);
text=string_replace(text, "dry", "wet", true);
text=string_replace(text, "normal", "weird", true);
text=string_replace(text, "keyboard", "mouse", true);
text=string_replace(text, "voice", "nothingness", true);
text=string_replace(text, "we", "you", true);
cd("success",text, false);
}
void remove_punctuation()
{
text=input_box("text changer","Enter the text you would like the punctuation removed from.");
text=string_to_lower_case(text);
text=string_replace(text, ".", "", true);
text=string_replace(text, ",", "", true);
text=string_replace(text, "/", "", true);
text=string_replace(text, "~", "", true);
text=string_replace(text, "!", "", true);
text=string_replace(text, "@", "", true);
text=string_replace(text, "#", "", true);
text=string_replace(text, "$", "", true);
text=string_replace(text, "%", "", true);
text=string_replace(text, "^", "", true);
text=string_replace(text, "&", "", true);
text=string_replace(text, "*", "", true);
text=string_replace(text, "(", "", true);
text=string_replace(text, ")", "", true);
text=string_replace(text, "_", "", true);
text=string_replace(text, "+", "", true);
text=string_replace(text, "-", "", true);
text=string_replace(text, "=", "", true);
text=string_replace(text, "<", "", true);
text=string_replace(text, ">", "", true);
text=string_replace(text, ">", "", true);
text=string_replace(text, "?", "", true);
text=string_replace(text, ";", "", true);
text=string_replace(text, "'", "", true);
text=string_replace(text, ":", "", true);
text=string_replace(text, "&", "\"", true);
text=string_replace(text, "[", "", true);
text=string_replace(text, "]", "", true);
text=string_replace(text, "\\", "", true);
cd("success",text, false);
}
void reverse()
{
text=input_box("text changer","Enter the text you would like reversed.");
text=string_to_lower_case(text);
text=string_reverse(text);
cd("success",text, false);
}
void remove_spaces()
{
text=input_box("text changer","Enter the text you would like the spaces removed from.");
text=string_to_lower_case(text);
text=string_replace(text, " ", "", true);
cd("success",text, false);
}
void uncapitalize()
{
text=input_box("text changer","Enter the text you would like uncapitalized.");
text=string_to_lower_case(text);
cd("success",text, false);
}
