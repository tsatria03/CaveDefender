void encode()
{
text=input_box("text changer","Enter the text you would like base64 encoded.");
text=string_base64_encode(text);
cd("success",text, false);
}
void decode()
{
text=input_box("text changer","Enter the text you would like base64 decoded.");
text=string_base64_decode(text);
cd("success",text, false);
}
void clipboard_copy()
{
text=input_box("text copier","Enter the text you would like to copy to your clipboard.");
clipboard_copy_text(text);
alert("success", "text copied!");
}