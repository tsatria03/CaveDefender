textutils();
}
else if(m.get_item_name(mres)=="wordtonumber")
{
word_to_number();
textutils();
}
else if(m.get_item_name(mres)=="clipboardcopy")
{
clipboard_copy();
textutils();
}
}
void optionsmenu()
{
setmenu();
m.add_item_tts("Play logo on startup?");
m.add_item_tts("Change voice settings");
m.add_item_tts("Go Back.");
int mres=m.run("Select an option", true);;
if(mres==0 or mres==m.get_item_count())
{
saveoptiondata();
mainmenu();
}
else if(mres==1)
{
options("playlogo");
}
else if(mres==2)
{
ttsopts.run(tts);
optionsmenu();
}
}
void options(string option)
{
setmenu();
m.add_item_tts("On");
m.add_item_tts("Off");
m.add_item_tts("Go back");
int mres=m.run("Please select your setting", true);
if(mres==0)
{
optionsmenu();
}
else if(mres==1)
{
if(option=="playlogo")
{
playlogo=1;
}
optionsmenu();
}
else if(mres==2)
{
if(option=="playlogo")
{
playlogo=0;
}
optionsmenu();
}
else if(mres==3)
{
optionsmenu();
}
}