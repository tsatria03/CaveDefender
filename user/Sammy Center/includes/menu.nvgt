else if(m.get_item_name(mres)=="lightningpower")
{
m.fade_music(10);
lightningpower();
}
else if(m.get_item_name(mres)=="popper")
{
m.fade_music(10);
baloon_popper();
}
else if(m.get_item_name(mres)=="options")
{
m.fade_music(10);
optionsmenu();
}
else if(m.get_item_name(mres)=="cat and dog")
{
m.fade_music(10);
cat_and_dog();
}
else if(m.get_item_name(mres)=="avoid")
{
m.fade_music(10);
avoid_the_beeps();
}
else if(m.get_item_name(mres)=="chase")
{
m.fade_music(10);
car_chase();
}
else if(m.get_item_name(mres)=="water_escape")
{
m.fade_music(10);
water_escape();
}
else if(m.get_item_name(mres)=="shoot")
{
m.fade_music(10);
shoot_the_target();
}
else if(m.get_item_name(mres)=="moneyfall")
{
m.fade_music(10);
moneyfall();
}
else if(m.get_item_name(mres)=="gtn")
{
m.fade_music(10);
gtn();
}
else if(m.get_item_name(mres)=="textutils")
{
m.fade_music(10);
textutils();
}
else if(m.get_item_name(mres)=="minitimer")
{
m.fade_music(10);
minitimer();
}
else if(m.get_item_name(mres)=="relax")
{
m.fade_music(10);
relax();
}
else if(m.get_item_name(mres)=="ttss")
{
m.fade_music(10);
tts_sidescroller();
}
else if(m.get_item_name(mres)=="scores")
{
m.fade_music(10);
viewscores();
}
else if(m.get_item_name(mres)=="exitfun")
{
m.fade_music(10);
fun_exit();
}
else if (m.get_item_name(mres)=="runs")
{
mainmenu();
}
else if(m.get_item_name(mres)=="piano")
{
m.fade_music(10);
piano();
}
}
string loadfilesmenu(string intro="select a file", string dir="", string ext="", bool hide_ext=true)
{
string[] files=find_files(dir+"/*"+ext);
if(files.length() <= 0)
{
return "0";
}
setmenu();
for(uint i=0; i<files.length(); i++)
{
if(hide_ext==false)
{
m.add_item_tts(files[i], files[i]);
}
else
{
m.add_item_tts(string_replace(files[i], ext, "", true), files[i]);
}
}
int mres=m.run(intro, true);
if(mres==0)
{
return "";
}
else
{
return m.get_item_name(mres);
}
}
string loadfoldersmenu(string intro="select a folder", string dir="")
{
string[] folders=find_directories(dir);
if(folders.length() <= 0)
{
return "0";
}
setmenu();
for(uint i=0; i<folders.length(); i++)
{
m.add_item_tts(folders[i], folders[i]);
}
int mres=m.run(intro, true);
if(mres==0)
{
return "";
}
else
{
return m.get_item_name(mres);
}
}
void setmenu(bool main=false)
{
reset();
set_sound_storage("sounds/main.dat");
m.reset(true);
m.repeat_items_at_edges=true;
m.edge_sound="menuedge.ogg";
m.click_sound="menuclick.ogg";
m.enable_up_and_down=true;
m.enable_left_and_right=true;
m.enable_side_scrolling=false;
m.enter_sound="menuselect.ogg";
m.enable_home_and_end=true;
m.wrap=false;
if(main==true)
{
m.add_music("menumus.ogg");
m.open_sound="menuopen.ogg";
}
}
void textutils()
{
setmenu();
m.add_item_tts("Butcherizer", "butcherize");
m.add_item_tts("Base64 Decode", "decode");
m.add_item_tts("Base64 Encode", "encode");
m.add_item_tts("Capitalizer", "capitalize");
m.add_item_tts("changer", "change");
m.add_item_tts("clipboard copier", "clipboardcopy");
m.add_item_tts("punctuation remover", "punctuation");
m.add_item_tts("reverser", "reverse");
m.add_item_tts("Spaces Remover", "removespaces");
m.add_item_tts("uncapitalizer", "uncapitalize");
m.add_item_tts("Word to number", "wordtonumber");
m.add_item_tts("go back");
int mres=m.run("text utilities menu", true);
if(mres==0 or mres==m.get_item_count())
{
mainmenu();
}
else if(m.get_item_name(mres)=="butcherize")
{
butcherize();
