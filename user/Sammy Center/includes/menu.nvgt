}
else if(m.get_item_name(mres)=="capitalize")
{
capitalize();
textutils();
}
else if(m.get_item_name(mres)=="change")
{
change();
textutils();
}
else if(m.get_item_name(mres)=="punctuation")
{
remove_punctuation();
textutils();
}
else if(m.get_item_name(mres)=="reverse")
{
reverse();
textutils();
}
else if(m.get_item_name(mres)=="removespaces")
{
remove_spaces();
